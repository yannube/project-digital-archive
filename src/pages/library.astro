---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "../lib/sanity";

const query = `
*[_type == "archiveItem" && category == "resource"] | order(year desc) {
  title,
  slug,
  year,
  description,
  tags,
  contributor,
  location,
  "imageUrl": image.asset->url
}
`;

const libraryItems = await sanityClient.fetch(query);
---

<BaseLayout
  title="Library"
  description="Historical documents, reports, publications, and preserved Scouting materials from the Maldives."
>
  <section class="page-hero library-hero">
    <div class="container">
      <span class="section-label">Research & Documentation</span>

      <h1>Library</h1>

      <p>
        A curated collection of historical records, reports,
        publications, guides, and preserved Scouting materials
        from the Maldives.
      </p>
    </div>
  </section>

  <section class="library-intro">
    <div class="container library-intro__inner">
      <div>
        <span class="section-label">Archive Repository</span>

        <h2>
          Preserving documents that shape the story of
          Scouting in the Maldives.
        </h2>
      </div>

      <p>
        The Library serves as a digital repository
        for educational materials, historical reports,
        publications, project documents, and research
        connected to the Scouting movement in the Maldives.
      </p>
    </div>
  </section>

  <section class="section library-section">
    <div class="container">
      <div class="section-header text-center fade-in">
        <span class="section-label">The Collection</span>

        <h2>Archive Library</h2>

        <div class="divider divider--center"></div>

        <p>
          Browse archived reports, historical documents,
          educational materials, and preserved records.
        </p>
      </div>

      {libraryItems.length > 0 ? (
        <div class="library-grid">
          {libraryItems.map((item: any) => (
            <a
              href={`/archive/${item.slug.current}`}
              class="library-card fade-in"
            >
              <div class="library-card__visual">
                {item.imageUrl ? (
                  <img
                    src={item.imageUrl}
                    alt={item.title}
                    class="library-card__image"
                  />
                ) : (
                  <div class="library-card__placeholder">
                    <span class="library-card__label">Library Item</span>

                    {item.year && (
                      <span class="library-card__year">
                        {item.year}
                      </span>
                    )}
                  </div>
                )}
              </div>

              <div class="library-card__content">
                <div class="library-card__meta">
                  {item.year && (
                    <span>{item.year}</span>
                  )}

                  {item.location && (
                    <span>{item.location}</span>
                  )}
                </div>

                <h3>{item.title}</h3>

                {item.description && (
                  <p>{item.description}</p>
                )}

                {item.tags && (
                  <div class="library-tags">
                    {item.tags.map((tag: string) => (
                      <span class="library-tag">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <div class="library-footer">
                  {item.contributor && (
                    <small>
                      By {item.contributor}
                    </small>
                  )}

                  <strong>
                    View Library Item →
                  </strong>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <h3>No library items added yet.</h3>

          <p>
            Add archive items in Sanity using
            category <strong>resource</strong>.
          </p>
        </div>
      )}
    </div>
  </section>

  <section class="library-highlight">
    <div class="container library-highlight__inner">
      <div class="fade-in">
        <span class="section-label">Preservation</span>

        <h2>
          Why the Library matters
        </h2>

        <p>
          Historical reports, publications, photographs,
          and educational materials help preserve the
          memory and development of Scouting for future
          generations.
        </p>
      </div>

      <div class="highlight-grid">
        <div class="highlight-card fade-in">
          <span>01</span>

          <h3>Research</h3>

          <p>
            Provides reliable material for students,
            researchers, and historians.
          </p>
        </div>

        <div class="highlight-card fade-in">
          <span>02</span>

          <h3>Education</h3>

          <p>
            Supports learning and public awareness
            about the history of Scouting.
          </p>
        </div>

        <div class="highlight-card fade-in">
          <span>03</span>

          <h3>Preservation</h3>

          <p>
            Ensures important historical records are
            not lost over time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .library-hero p {
      max-width: 58ch;
      margin-inline: auto;
    }

    .library-intro {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding-block: var(--space-16);
    }

    .library-intro__inner {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-12);
      align-items: start;
    }

    .library-intro h2 {
      max-width: 13ch;
      color: var(--color-green);
    }

    .library-intro p {
      color: var(--color-ink-muted);
      line-height: 1.9;
      font-size: var(--text-md);
      max-width: 65ch;
    }

    .library-section {
      background: var(--color-cream);
    }

    .library-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
      gap: var(--space-8);
      margin-top: var(--space-12);
    }

    .library-card {
      display: flex;
      flex-direction: column;
      background: var(--color-cream-light);
      border: 1px solid var(--color-border);
      border-radius: var(--border-radius-md);
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition:
        transform var(--transition-base),
        box-shadow var(--transition-base);
    }

    .library-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }

    .library-card__visual {
      height: 260px;
      overflow: hidden;
      background: var(--color-cream);
    }

    .library-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .library-card:hover .library-card__image {
      transform: scale(1.05);
    }

    .library-card__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--space-4);
      background:
        linear-gradient(
          135deg,
          rgba(67, 2, 1, 0.08),
          rgba(42, 38, 24, 0.04)
        );
    }

    .library-card__label {
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .library-card__year {
      color: var(--color-green);
      font-family: var(--font-serif);
      font-size: var(--text-3xl);
      font-weight: 700;
    }

    .library-card__content {
      padding: var(--space-8);
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .library-card__meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .library-card h3 {
      color: var(--color-green);
      font-size: var(--text-xl);
      margin-bottom: var(--space-4);
      line-height: 1.3;
    }

    .library-card p {
      color: var(--color-ink-muted);
      line-height: 1.8;
      font-size: var(--text-sm);
    }

    .library-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: var(--space-6);
    }

    .library-tag {
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(67, 2, 1, 0.08);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 700;
    }

    .library-footer {
      margin-top: auto;
      padding-top: var(--space-7);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
    }

    .library-footer small {
      color: var(--color-ink-muted);
      font-size: var(--text-xs);
    }

    .library-footer strong {
      color: var(--color-red);
      font-size: var(--text-sm);
    }

    .empty-state {
      margin-top: var(--space-12);
      padding: var(--space-10);
      border-radius: var(--border-radius-md);
      border: 1px dashed var(--color-border);
      background: var(--color-cream-light);
      text-align: center;
    }

    .empty-state h3 {
      color: var(--color-green);
      margin-bottom: var(--space-2);
    }

    .empty-state p {
      color: var(--color-ink-muted);
    }

    .library-highlight {
      background: var(--color-green);
      padding-block: var(--space-20);
    }

    .library-highlight__inner {
      display: flex;
      flex-direction: column;
      gap: var(--space-12);
    }

    .library-highlight h2 {
      color: var(--color-cream);
      margin-bottom: var(--space-4);
    }

    .library-highlight p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.8;
    }

    .highlight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }

    .highlight-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--border-radius-md);
      padding: var(--space-8);
      backdrop-filter: blur(10px);
    }

    .highlight-card span {
      display: inline-block;
      margin-bottom: var(--space-4);
      color: var(--color-cream);
      font-family: var(--font-serif);
      font-size: var(--text-xl);
      font-weight: 700;
    }

    .highlight-card h3 {
      color: var(--color-cream);
      margin-bottom: var(--space-3);
    }

    .highlight-card p {
      color: var(--color-cream-dark);
      line-height: 1.7;
      font-size: var(--text-sm);
    }

    @media (max-width: 900px) {
      .library-intro__inner,
      .highlight-grid {
        grid-template-columns: 1fr;
      }

      .library-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 600px) {
      .library-card__visual {
        height: 220px;
      }

      .library-card__content {
        padding: var(--space-6);
      }

      .library-footer {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>