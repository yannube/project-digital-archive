---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy Policy for Mahaldheeb Scoutun Project Digital Archive."
>
  <section class="page-hero privacy-hero">
    <div class="container">
      <span class="section-label">Privacy & Data Use</span>

      <h1>
        Privacy<br />
        Policy
      </h1>

      <p>
        This Privacy Policy explains how Mahaldheeb Scoutun Project Digital Archive
        collects, reviews, stores, and uses information submitted through this website.
      </p>
    </div>
  </section>

  <section class="privacy-section">
    <div class="container privacy-layout">
      <aside class="privacy-sidebar">
        <div class="privacy-sidebar__card">
          <span class="section-label">Website</span>

          <h2>Mahaldheeb Scoutun</h2>

          <p>
            A Project Digital Archive initiative preserving the history, heritage,
            and legacy of Scouting in the Maldives.
          </p>
        </div>

        <div class="privacy-sidebar__card">
          <span class="section-label">Policy Status</span>

          <h2>Active Policy</h2>

          <p>
            This policy may be updated as the archive grows and new contribution,
            upload, storage, or content management systems are introduced.
          </p>
        </div>

        <div class="privacy-sidebar__card privacy-sidebar__card--highlight">
          <span class="section-label">Contact</span>

          <h2>Need help?</h2>

          <p>
            For correction, removal, or privacy-related concerns, please contact
            the archive team through the Contact page.
          </p>

          <a href="/contact" class="privacy-sidebar__link">
            Contact the Archive →
          </a>
        </div>
      </aside>

      <article class="privacy-content">
        <header class="privacy-content__header">
          <span class="section-label">Full Policy</span>

          <h2>Privacy Policy for Mahaldheeb Scoutun</h2>

          <div class="divider"></div>

          <p>
            Mahaldheeb Scoutun is a Project Digital Archive initiative created to
            preserve, present, and protect the history of Scouting in the Maldives.
            This website may collect information from visitors, contributors, Scout
            groups, veterans, leaders, sponsors, and members of the public who choose
            to contact the archive or submit materials.
          </p>
        </header>

        <div class="privacy-policy-list">
          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">01</span>

            <div class="privacy-policy-item__content">
              <h3>Information We Collect</h3>

              <p>
                When you use the contact or contribution form, we may collect
                information such as your full name, email address, contact number,
                Scout group or organisation, atoll, island, contribution type,
                title or subject, description, and any other information you choose
                to provide.
              </p>

              <p>
                If file uploads are enabled in the future, we may also collect
                submitted materials such as photographs, documents, certificates,
                project reports, videos, audio recordings, scanned records, or other
                archive-related files.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">02</span>

            <div class="privacy-policy-item__content">
              <h3>How We Use Submitted Information</h3>

              <p>
                Information submitted to the archive may be used for reviewing
                contributions, verifying historical details, contacting contributors,
                organising archive materials, preparing content for publication, and
                maintaining records related to Scouting history in the Maldives.
              </p>

              <p>
                Submitted materials may be reviewed by archive administrators before
                being accepted, edited for clarity, categorised, stored, or published
                on the website.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">03</span>

            <div class="privacy-policy-item__content">
              <h3>Archive Contributions</h3>

              <p>
                By submitting materials to Mahaldheeb Scoutun, you confirm that you
                own the materials or have permission to share them. You also confirm
                that the archive team may review, store, and use the submitted
                materials for historical, educational, documentation, and preservation
                purposes.
              </p>

              <p>
                Submitting materials does not automatically guarantee publication.
                Archive administrators may choose not to publish materials if they
                are incomplete, inaccurate, inappropriate, unverifiable, duplicated,
                or submitted without proper permission.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">04</span>

            <div class="privacy-policy-item__content">
              <h3>Personal Contact Details</h3>

              <p>
                Personal contact details such as phone numbers and email addresses
                are used mainly for communication, clarification, verification, and
                follow-up regarding submissions. These contact details will not
                normally be displayed publicly on the website.
              </p>

              <p>
                If a submitted item includes personal information about other people,
                the archive team may review the material carefully before publication.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">05</span>

            <div class="privacy-policy-item__content">
              <h3>Historical and Public Information</h3>

              <p>
                Some materials submitted to the archive may contain names, roles,
                positions, dates, event details, photographs, or other historical
                records. These may be published when they are relevant to documenting
                Scouting history and when the archive team believes publication is
                appropriate.
              </p>

              <p>
                Where possible, the archive aims to present information respectfully,
                accurately, and in a way that protects the dignity of individuals and
                organisations represented in the archive.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">06</span>

            <div class="privacy-policy-item__content">
              <h3>File Storage and Third-Party Services</h3>

              <p>
                This website may use trusted third-party services for form
                submissions, file uploads, hosting, analytics, content management,
                or storage. These services may process submitted information only
                for the purpose of operating the website and managing archive
                submissions.
              </p>

              <p>
                Examples may include website hosting providers, form handling
                services, content management systems, email services, or file storage
                platforms. The exact services used may change as the archive develops.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">07</span>

            <div class="privacy-policy-item__content">
              <h3>Data Security</h3>

              <p>
                Reasonable steps will be taken to protect submitted information and
                archive materials from unauthorised access, misuse, loss, or accidental
                disclosure. However, no online system can be guaranteed to be completely
                secure.
              </p>

              <p>
                Contributors should avoid submitting highly sensitive personal
                information unless it is necessary for archive documentation.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">08</span>

            <div class="privacy-policy-item__content">
              <h3>Accuracy of Information</h3>

              <p>
                The archive aims to preserve accurate historical information. However,
                some historical records may be incomplete, unclear, or based on
                available sources at the time of publication.
              </p>

              <p>
                Contributors are encouraged to provide dates, locations, names,
                captions, background details, and source information whenever possible.
                The archive team may update or correct published information when
                better evidence becomes available.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">09</span>

            <div class="privacy-policy-item__content">
              <h3>Requests for Correction or Removal</h3>

              <p>
                If you believe that information published on the website is inaccurate,
                inappropriate, or should be removed, you may contact the archive team.
                Requests will be reviewed, and reasonable corrections or removals may
                be made where appropriate.
              </p>

              <p>
                The archive may retain internal records of submissions for
                documentation, verification, or administrative purposes.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">10</span>

            <div class="privacy-policy-item__content">
              <h3>Children and Youth Materials</h3>

              <p>
                Since Scouting involves young people, the archive will take care when
                handling materials that include children or youth members. Photographs
                or records involving minors may be reviewed carefully before publication.
              </p>

              <p>
                If a concern is raised regarding the publication of a photograph or
                record involving a minor, the archive team may remove or restrict the
                material while the concern is reviewed.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">11</span>

            <div class="privacy-policy-item__content">
              <h3>External Links</h3>

              <p>
                This website may contain links to external websites, documents,
                videos, or resources. Mahaldheeb Scoutun is not responsible for the
                privacy practices, content, or security of external websites.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">12</span>

            <div class="privacy-policy-item__content">
              <h3>Changes to This Policy</h3>

              <p>
                This Privacy Policy may be updated as the website grows, especially
                when new systems such as file uploads, Sanity CMS, archive submissions,
                custom domain email, or other contribution systems are introduced.
              </p>

              <p>
                Updated versions of this policy will be published on this page.
              </p>
            </div>
          </section>

          <section class="privacy-policy-item">
            <span class="privacy-policy-item__number">13</span>

            <div class="privacy-policy-item__content">
              <h3>Contact</h3>

              <p>
                For privacy concerns, correction requests, removal requests, or
                questions about submitted materials, please contact the archive
                through the Contact page.
              </p>
            </div>
          </section>
        </div>

        <div class="privacy-note">
  <div class="privacy-note__content">
    <div class="privacy-note__label">Important Note</div>

    <p>
      This policy is written for the Mahaldheeb Scoutun Project Digital
      Archive website and may be refined later with formal legal review if
      required.
    </p>
  </div>
</div>

        <div class="privacy-actions">
          <a href="/contact" class="btn btn-primary">Contact the Archive</a>
          <a href="/" class="btn btn-outline">Back to Home</a>
        </div>
      </article>
    </div>
  </section>

  <style>
    .privacy-hero p {
      max-width: 64ch;
      margin-inline: auto;
    }

    .privacy-section {
      background: var(--color-cream);
      padding-block: clamp(4.5rem, 8vw, 7rem);
    }

    .privacy-layout {
      display: grid;
      grid-template-columns: 290px minmax(0, 1fr);
      gap: clamp(3.25rem, 7vw, 5.75rem);
      align-items: start;
      max-width: 1120px;
      margin-inline: auto;
    }

    .privacy-sidebar {
      position: sticky;
      top: 120px;
      display: grid;
      gap: var(--space-5);
    }

    .privacy-sidebar__card {
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.46),
          rgba(255, 255, 255, 0.12)
        ),
        var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 20px;
      padding: var(--space-6);
      box-shadow:
        0 16px 38px rgba(42, 38, 24, 0.045),
        0 1px 0 rgba(255, 255, 255, 0.45) inset;
    }

    .privacy-sidebar__card--highlight {
      border-color: rgba(125, 6, 5, 0.22);
      background:
        linear-gradient(
          135deg,
          rgba(125, 6, 5, 0.06),
          transparent 48%
        ),
        var(--color-cream-light);
    }

    .privacy-sidebar__card h2 {
      color: var(--color-green);
      font-size: var(--text-xl);
      line-height: 1.18;
      margin: var(--space-4) 0 var(--space-3);
    }

    .privacy-sidebar__card p {
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.78;
      max-width: none;
      margin: 0;
    }

    .privacy-sidebar__link {
      display: inline-block;
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      margin-top: var(--space-5);
      transition:
        color var(--transition-fast),
        transform var(--transition-fast);
    }

    .privacy-sidebar__link:hover {
      color: var(--color-green);
      transform: translateX(4px);
    }

    .privacy-content {
      max-width: 760px;
      min-width: 0;
      opacity: 1;
      transform: none;
    }

    .privacy-content__header {
      margin-bottom: clamp(3rem, 6vw, 4.5rem);
      padding-bottom: clamp(2.25rem, 4.5vw, 3.5rem);
      border-bottom: 1px solid rgba(42, 38, 24, 0.12);
    }

    .privacy-content h2 {
      color: var(--color-green);
      font-size: clamp(2.35rem, 5vw, 4rem);
      line-height: 1.08;
      margin: var(--space-4) 0 var(--space-5);
      max-width: 12ch;
    }

    .privacy-content__header p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.92;
      margin-top: var(--space-7);
      max-width: 68ch;
    }

    .privacy-policy-list {
      display: grid;
      gap: clamp(2.5rem, 5vw, 3.75rem);
    }

    .privacy-policy-item {
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr);
      gap: clamp(1.35rem, 3vw, 2rem);
      align-items: start;
      padding-bottom: clamp(2.5rem, 5vw, 3.75rem);
      border-bottom: 1px solid rgba(42, 38, 24, 0.1);
    }

    .privacy-policy-item:last-child {
      padding-bottom: 0;
      border-bottom: 0;
    }

    .privacy-policy-item__number {
      font-family: var(--font-serif);
      color: rgba(125, 6, 5, 0.24);
      font-size: clamp(2rem, 4.5vw, 3.05rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.04em;
    }

    .privacy-policy-item__content {
      min-width: 0;
    }

    .privacy-policy-item h3 {
      color: var(--color-green);
      font-size: clamp(1.3rem, 2vw, 1.7rem);
      line-height: 1.22;
      margin-bottom: var(--space-5);
    }

    .privacy-policy-item p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.9;
      margin-bottom: var(--space-5);
      max-width: 68ch;
    }

    .privacy-policy-item p:last-child {
      margin-bottom: 0;
    }

    .privacy-note {
  margin-top: clamp(3.75rem, 7vw, 5.25rem);
  max-width: 68ch;
  border-radius: 24px;
  border: 1px solid rgba(125, 6, 5, 0.18);
  background:
    linear-gradient(
      135deg,
      rgba(125, 6, 5, 0.06),
      rgba(125, 6, 5, 0.025) 58%,
      rgba(255, 255, 255, 0.2)
    ),
    var(--color-cream-light);
  box-shadow:
    0 18px 44px rgba(42, 38, 24, 0.06),
    0 1px 0 rgba(255, 255, 255, 0.45) inset;
  overflow: hidden;
}

.privacy-note__content {
  position: relative;
  padding: clamp(2rem, 4vw, 2.5rem) clamp(2.25rem, 5vw, 3rem);
}

.privacy-note__content::before {
  content: "";
  position: absolute;
  left: clamp(1.15rem, 2vw, 1.45rem);
  top: clamp(2rem, 4vw, 2.5rem);
  bottom: clamp(2rem, 4vw, 2.5rem);
  width: 4px;
  border-radius: 999px;
  background: var(--color-red);
}

.privacy-note__label {
  color: var(--color-red);
  font-size: var(--text-xs);
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
  line-height: 1.35;
  padding-left: clamp(1.75rem, 4vw, 2.25rem);
}

.privacy-note p {
  color: var(--color-ink-muted);
  font-size: var(--text-sm);
  line-height: 1.9;
  max-width: 58ch;
  margin: 0;
  padding-left: clamp(1.75rem, 4vw, 2.25rem);
}

    .privacy-actions {
      margin-top: var(--space-10);
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
      align-items: center;
    }

    @media (max-width: 1000px) {
      .privacy-layout {
        grid-template-columns: 1fr;
        gap: var(--space-10);
      }

      .privacy-sidebar {
        position: static;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .privacy-content {
        max-width: none;
      }
    }

    @media (max-width: 820px) {
      .privacy-sidebar {
        grid-template-columns: 1fr;
      }

      .privacy-policy-item {
        grid-template-columns: 1fr;
        gap: var(--space-4);
      }

      .privacy-policy-item__number {
        font-size: 2.55rem;
      }
    }

    @media (max-width: 700px) {
      .privacy-section {
        padding-block: var(--space-12);
      }

      .privacy-content__header {
        margin-bottom: var(--space-10);
        padding-bottom: var(--space-8);
      }

      .privacy-policy-list {
        gap: var(--space-10);
      }

      .privacy-policy-item {
        padding-bottom: var(--space-10);
      }

      .privacy-note__content {
  padding: var(--space-6) var(--space-6) var(--space-6) var(--space-7);
}

.privacy-note__content::before {
  left: var(--space-4);
  top: var(--space-6);
  bottom: var(--space-6);
}

.privacy-note__label,
.privacy-note p {
  padding-left: var(--space-6);
}

      .privacy-actions {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>