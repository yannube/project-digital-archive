---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "../lib/sanity";

const query = `
*[_type == "archiveItem"] | order(year desc) {
  title,
  slug,
  year,
  category,
  description,
  tags,
  location,
  contributor,
  "imageUrl": image.asset->url
}
`;

const archiveItems = await sanityClient.fetch(query);

const categories = [
  "all",
  "history",
  "photo",
  "veteran",
  "project",
  "resource"
];
---

<BaseLayout title="Digital Archive">

<section class="archive-page">

  <div class="container">

    <div class="archive-header fade-in">

      <span class="archive-label">
        Digital Archive System
      </span>

      <h1>Archive Collection</h1>

      <p>
        Browse historical records, photographs, oral histories,
        projects, and preserved materials documenting
        Scouting in the Maldives.
      </p>

    </div>

    <!-- SEARCH -->
    <div class="archive-controls fade-in">

      <div class="archive-search-wrap">
        <input
          type="text"
          id="archiveSearch"
          placeholder="Search archive records..."
          class="archive-search"
        />
      </div>

      <div class="archive-filters">

        {categories.map((category) => (
          <button
            class={`archive-filter ${category === "all" ? "active" : ""}`}
            data-category={category}
          >
            {category}
          </button>
        ))}

      </div>

    </div>

    <!-- GRID -->
    <div class="archive-grid" id="archiveGrid">

      {archiveItems.map((item: any) => (

        <article
          class="archive-card"
          data-title={item.title?.toLowerCase()}
          data-category={item.category}
          data-tags={item.tags?.join(" ").toLowerCase()}
          data-description={item.description?.toLowerCase()}
        >

          <a href={`/archive/${item.slug.current}`}>

            {item.imageUrl && (
              <div class="archive-image">
                <img
                  src={item.imageUrl}
                  alt={item.title}
                />
              </div>
            )}

            <div class="archive-card-top">

              <span class="archive-year">
                {item.year}
              </span>

              <span class={`archive-category archive-category--${item.category}`}>
                {item.category}
              </span>

            </div>

            <h2>{item.title}</h2>

            <p>{item.description}</p>

            <div class="archive-meta">

              {item.location && (
                <span>📍 {item.location}</span>
              )}

              {item.contributor && (
                <span>👤 {item.contributor}</span>
              )}

            </div>

            {item.tags && (
              <div class="archive-tags">

                {item.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}

              </div>
            )}

          </a>

        </article>

      ))}

    </div>

  </div>

</section>

<script>
  const searchInput = document.getElementById("archiveSearch") as HTMLInputElement | null;
  const cards = document.querySelectorAll<HTMLElement>(".archive-card");
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".archive-filter");

  let activeCategory = "all";

  function filterArchive() {
    if (!searchInput) return;

    const search = searchInput.value.toLowerCase();

    cards.forEach((card) => {
      const title = card.dataset.title || "";
      const desc = card.dataset.description || "";
      const tags = card.dataset.tags || "";
      const category = card.dataset.category || "";

      const matchesSearch =
        title.includes(search) ||
        desc.includes(search) ||
        tags.includes(search);

      const matchesCategory =
        activeCategory === "all" || category === activeCategory;

      card.style.display = matchesSearch && matchesCategory ? "block" : "none";
    });
  }

  searchInput?.addEventListener("input", filterArchive);

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      filterButtons.forEach((btn) => btn.classList.remove("active"));

      button.classList.add("active");
      activeCategory = button.dataset.category || "all";

      filterArchive();
    });
  });
</script>

<style>

.archive-page {
  padding: 120px 0;
}

.archive-header {
  text-align: center;
  margin-bottom: 60px;
}

.archive-label {
  display: inline-block;
  padding: 10px 18px;
  border: 1px solid rgba(67, 2, 1, 0.2);
  border-radius: 999px;
  color: #430201;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 20px;
}

.archive-header h1 {
  font-size: 4rem;
  margin-bottom: 20px;
}

.archive-header p {
  max-width: 720px;
  margin: 0 auto;
  color: #666;
  line-height: 1.8;
  font-size: 1.1rem;
}

/* CONTROLS */

.archive-controls {
  margin-bottom: 60px;
}

.archive-search-wrap {
  margin-bottom: 24px;
}

.archive-search {
  width: 100%;
  padding: 18px 24px;

  border-radius: 18px;
  border: 1px solid rgba(0,0,0,0.08);

  background: white;

  font-size: 1rem;
}

.archive-search:focus {
  outline: none;
  border-color: #430201;
}

.archive-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.archive-filter {
  padding: 10px 18px;
  border-radius: 999px;

  border: none;

  background: #f3f0eb;

  text-transform: capitalize;

  cursor: pointer;

  transition: all 0.3s ease;
}

.archive-filter.active {
  background: #430201;
  color: white;
}

.archive-filter:hover {
  transform: translateY(-2px);
}

/* GRID */

.archive-grid {
  display: grid;
  grid-template-columns:
    repeat(auto-fit, minmax(380px, 1fr));

  gap: 40px;
}

.archive-card {
  background: white;
  border-radius: 28px;

  overflow: hidden;

  border: 1px solid rgba(0,0,0,0.08);

  transition: all 0.3s ease;
}

.archive-card a {
  text-decoration: none;
  color: inherit;
}

.archive-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 50px rgba(0,0,0,0.08);
}

.archive-image {
  width: 100%;
  height: 260px;
  overflow: hidden;
}

.archive-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;

  transition: transform 0.5s ease;
}

.archive-card:hover .archive-image img {
  transform: scale(1.05);
}

.archive-card-top {
  display: flex;
  justify-content: space-between;

  padding: 28px 28px 0;
}

.archive-year {
  color: #430201;
  font-weight: 700;
}

.archive-category {
  padding: 6px 12px;
  border-radius: 999px;

  background: rgba(67, 2, 1, 0.08);

  color: #430201;

  font-size: 0.75rem;
  text-transform: uppercase;
}

.archive-card h2 {
  padding: 20px 28px 0;
  margin-bottom: 14px;

  font-size: 1.6rem;
}

.archive-card p {
  padding: 0 28px;
  color: #555;
  line-height: 1.8;
}

.archive-meta {
  display: flex;
  flex-direction: column;

  gap: 6px;

  padding: 24px 28px 0;

  color: #777;
  font-size: 0.9rem;
}

.archive-tags {
  display: flex;
  flex-wrap: wrap;

  gap: 10px;

  padding: 24px 28px 28px;
}

.tag {
  padding: 8px 14px;
  border-radius: 999px;

  background: #f3f0eb;

  font-size: 0.8rem;
}

@media (max-width: 768px) {

  .archive-header h1 {
    font-size: 3rem;
  }

  .archive-grid {
    grid-template-columns: 1fr;
  }

}

</style>