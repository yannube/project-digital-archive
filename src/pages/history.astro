---

<BaseLayout
  title="Scouting History"
  description="The history of Scouting in the Maldives, from its early roots to the growth of a nationwide movement."
>
  <section class="page-hero history-hero">
    <div class="container">
      <span class="section-label">Scouting History</span>

      <h1>Scouting History<br />of the Maldives</h1>

      <p>
        From its roots at Majeediyya School to a nationwide movement, this page
        documents the story of Scouting in the Maldives through written history,
        key moments, and the people who helped shape the movement.
      </p>
    </div>
  </section>

  <section class="history-overview">
    <div class="container history-overview__inner">
      <div class="history-overview__text fade-in">
        <span class="section-label">Overview</span>

        <h2>A legacy built through service, leadership, and youth development.</h2>

        <p>
          The story of Scouting in the Maldives is closely connected to education,
          community service, leadership training, and national development. What
          began through school-based activity in Malé eventually grew into a
          nationwide movement reaching islands across the country.
        </p>

        <p>
          This page presents the historical information of the movement in written
          form. For a year-by-year view of major milestones, visit the dedicated
          Timeline page.
        </p>

        <a href="/timeline" class="btn btn-primary">
          View Full Timeline
        </a>
      </div>

      <div class="history-overview__year fade-in">
        <span>1961</span>
        <p>Confirmed beginning of organized Scouting in the Maldives</p>
      </div>
    </div>
  </section>

  <section class="history-article">
    <div class="container history-article__container">
      <header class="history-article__header fade-in">
        <span class="section-label">Written History</span>

        <h2>The Story of Scouting in the Maldives</h2>

        <div class="divider divider--center"></div>

        <p>
          A written record of the major stages, challenges, milestones, and
          achievements that shaped the Scout movement in the Maldives.
        </p>
      </header>

      <div class="history-content">
        {historySections.map((section) => (
          <article class="history-section fade-in" id={section.id}>
            <div class="history-section__side">
              <span class="history-section__number">{section.number}</span>
              <span class="history-section__eyebrow">{section.eyebrow}</span>
            </div>

            <div class="history-section__main">
              <h2>{section.title}</h2>

              <div class="divider"></div>

              {section.body && section.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}

              {section.image && (
                <figure
                  class={`history-image ${
                    section.id === "formation-of-sam" ? "history-image--logo" : ""
                  }`}
                >
                  <img
                    src={section.image}
                    alt={section.imageAlt}
                    loading="lazy"
                  />
                </figure>
              )}

              {section.listIntro && (
                <p class="history-list-intro">
                  {section.listIntro}
                </p>
              )}

              {section.list && (
                <ul class="history-list">
                  {section.list.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}

              {section.closing && section.closing.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="key-figures-section">
    <div class="container key-figures-container">
      <header class="key-figures-header fade-in">
        <span class="section-label">Leadership Register</span>

        <h2>Key Figures in Early Scouting</h2>

        <div class="divider divider--center"></div>

        <p>
          A developing leadership register of national patrons, governance heads,
          and executive leaders who contributed to the recognition, administration,
          and growth of Scouting in the Maldives.
        </p>

        <p class="key-figures-note">
          Note: Some early tenures are listed as known periods because a complete
          uninterrupted public register is not yet available.
        </p>
      </header>

      <div class="leadership-groups">
        {leadershipGroups.map((group) => (
          <section class="leadership-group fade-in">
            <div class="leadership-group__heading">
              <span class="section-label">{group.heading}</span>
              <p>{group.description}</p>
            </div>

            <div class="leadership-grid">
              {group.people.map((person) => (
                <article class="leader-card">
                  <div class="leader-card__photo">
                    <img
                      src={person.image}
                      alt={person.name}
                      loading="lazy"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
                    />
                    <span>{person.initials}</span>
                  </div>

                  <div class="leader-card__body">
                    <h3>{person.name}</h3>
                    <p>{person.title}</p>
                    <small>{person.duration}</small>
                    <span class="leader-card__note">{person.note}</span>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="history-timeline-cta">
    <div class="container history-timeline-cta__inner">
      <div class="fade-in">
        <span class="section-label">Milestones</span>

        <h2>Want to explore the events year by year?</h2>

        <p>
          The written history page gives the full context. The Timeline page
          presents the same journey through dates, milestones, and key turning
          points in a more visual way.
        </p>
      </div>

      <a href="/timeline" class="btn btn-primary fade-in">
        Open Timeline
      </a>
    </div>
  </section>

  <style>
    .history-hero p {
      max-width: 64ch;
      margin-inline: auto;
    }

    .history-overview {
      background-color: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding-block: var(--space-16);
    }

    .history-overview__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: var(--space-12);
      align-items: center;
    }

    .history-overview__text {
      max-width: 760px;
    }

    .history-overview__text h2 {
      color: var(--color-green);
      font-size: clamp(2.4rem, 5vw, 4.2rem);
      line-height: 1.08;
      max-width: 16ch;
      margin: var(--space-4) 0 var(--space-5);
    }

    .history-overview__text p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.85;
      max-width: 68ch;
      margin-bottom: var(--space-5);
    }

    .history-overview__year {
      min-height: 240px;
      border-radius: var(--border-radius-md);
      background-color: var(--color-green);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      box-shadow: var(--shadow-md);
      text-align: center;
    }

    .history-overview__year span {
      font-family: var(--font-serif);
      font-size: clamp(3.5rem, 7vw, 5.8rem);
      font-weight: 800;
      color: var(--color-cream);
      line-height: 0.95;
    }

    .history-overview__year p {
      color: var(--color-cream-dark);
      font-size: var(--text-xs);
      font-weight: 800;
      letter-spacing: 0.1em;
      line-height: 1.65;
      text-transform: uppercase;
      max-width: 24ch;
      margin-top: var(--space-5);
    }

    .history-article {
      background-color: var(--color-cream);
      padding-block: var(--space-18);
    }

    .history-article__container {
      max-width: 1050px;
    }

    .history-article__header {
      text-align: center;
      max-width: 780px;
      margin-inline: auto;
      margin-bottom: var(--space-16);
    }

    .history-article__header h2 {
      color: var(--color-green);
      font-size: clamp(2.3rem, 5vw, 4rem);
      line-height: 1.08;
      margin: var(--space-4) 0 var(--space-4);
    }

    .history-article__header p {
      color: var(--color-ink-muted);
      line-height: 1.8;
      max-width: 62ch;
      margin-inline: auto;
    }

    .history-content {
      display: flex;
      flex-direction: column;
    }

    .history-section {
      display: grid;
      grid-template-columns: 130px minmax(0, 1fr);
      gap: var(--space-9);
      padding-block: var(--space-12);
      border-top: 1px solid var(--color-border);
      scroll-margin-top: 120px;
    }

    .history-section:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .history-section__side {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      padding-top: 0.25rem;
    }

    .history-section__number {
      font-family: var(--font-serif);
      color: rgba(125, 6, 5, 0.34);
      font-size: var(--text-3xl);
      font-weight: 800;
      line-height: 1;
    }

    .history-section__eyebrow {
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.13em;
      line-height: 1.35;
      text-transform: uppercase;
      max-width: 12ch;
    }

    .history-section__main {
      min-width: 0;
      max-width: 770px;
      width: 100%;
    }

    .history-section__main h2 {
      color: var(--color-green);
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.08;
      margin-bottom: var(--space-4);
    }

    .history-section__main p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.9;
      margin-bottom: var(--space-5);
      max-width: 70ch;
    }

    .history-image {
      width: fit-content;
      max-width: min(360px, 100%);
      margin-top: var(--space-6);
      margin-bottom: var(--space-7);
      margin-left: calc(50% - 65px);
      transform: translateX(-50%);
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--color-border);
      background-color: var(--color-cream-light);
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .history-image img {
      display: block;
      width: auto;
      max-width: 100%;
      max-height: 230px;
      height: auto;
      object-fit: contain;
    }

    .history-image--logo {
      max-width: 230px;
