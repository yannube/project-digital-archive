---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "../lib/sanity";

const query = `
*[_type == "archiveItem" && category == "project"] | order(year desc) {
  _id,
  title,
  slug,
  year,
  description,
  location,
  contributor,
  tags,
  "imageUrl": image.asset->url
}
`;

const sanityProjects = await sanityClient.fetch(query);

const fallbackProjects = [
  {
    _id: "fallback-1",
    title: "Fit Ramadan",
    slug: null,
    year: "2023",
    description:
      "A public health awareness initiative designed to encourage healthy lifestyles during and after Ramadan.",
    location: "Maldives",
    contributor: "Scout Association of Maldives",
    tags: ["health", "wellbeing", "ramadan", "SDG3"],
    imageUrl: null,
  },
  {
    _id: "fallback-2",
    title: "Muraka Kudhin — Coral Restoration Project",
    slug: null,
    year: "2023",
    description:
      "A marine conservation initiative focused on reef rehabilitation and coral restoration through coral propagation in Villimalé’s coral nursery.",
    location: "Villimalé",
    contributor: "Scout Association of Maldives",
    tags: ["environment", "marine conservation", "SDG14"],
    imageUrl: null,
  },
];

const projects = sanityProjects.length > 0 ? sanityProjects : fallbackProjects;
---

<BaseLayout
  title="Scouting Projects"
  description="Community-driven Scouting projects focused on service, leadership, impact, and sustainable development."
>
  <section class="page-hero projects-hero">
    <div class="container">
      <span class="section-label">Action & Service</span>
      <h1>Scouting<br />Projects</h1>
      <p>
        A record of service, leadership, adventure, and community impact by
        Scouts across the Maldives.
      </p>
    </div>
  </section>

  <section class="projects-intro">
    <div class="container projects-intro__inner">
      <div>
        <span class="section-label">Impact Archive</span>
        <h2>Projects that turn Scouting values into action.</h2>
      </div>

      <p>
        From environmental conservation to health awareness and Rover journeys,
        these projects document how Scouts serve communities, protect nature,
        develop leadership, and contribute to national development.
      </p>
    </div>
  </section>

  <section class="section projects-section">
    <div class="container">
      <div class="section-header text-center fade-in">
        <span class="section-label">The Collection</span>
        <h2>Featured Projects</h2>
        <div class="divider divider--center"></div>
        <p>
          Each project record is connected to the digital archive and can be
          expanded with photos, descriptions, partners, and impact notes.
        </p>
      </div>

      <div class="projects-grid">
        {projects.map((project: any) => {
          const link = project.slug?.current
            ? `/archive/${project.slug.current}`
            : "/archive";

          return (
            <a href={link} class="project-card fade-in">
              {project.imageUrl && (
                <div class="project-card__image">
                  <img src={project.imageUrl} alt={project.title} />
                </div>
              )}

              <div class="project-card__content">
                <div class="project-card__meta">
                  {project.year && <span>{project.year}</span>}
                  {project.location && <span>📍 {project.location}</span>}
                </div>

                <h3>{project.title}</h3>

                {project.description && <p>{project.description}</p>}

                {Array.isArray(project.tags) && (
                  <div class="project-tags">
                    {project.tags.map((tag: string) => (
                      <span class="project-tag">{tag}</span>
                    ))}
                  </div>
                )}

                <strong class="project-link">View Project →</strong>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section--sm project-impact">
    <div class="container project-impact__grid">
      <div class="impact-card fade-in">
        <span>01</span>
        <h3>Service</h3>
        <p>
          Projects show how Scouts contribute directly to communities through
          voluntary action.
        </p>
      </div>

      <div class="impact-card fade-in">
        <span>02</span>
        <h3>Leadership</h3>
        <p>
          Each initiative develops planning, teamwork, communication, and
          responsibility.
        </p>
      </div>

      <div class="impact-card fade-in">
        <span>03</span>
        <h3>Sustainability</h3>
        <p>
          Environmental and social projects highlight Scouting’s connection to
          long-term national impact.
        </p>
      </div>
    </div>
  </section>

  <section class="projects-cta-band">
    <div class="container projects-cta-band__inner">
      <div class="fade-in">
        <h3>Have a Scouting project to archive?</h3>
        <p>
          Submit project details, photos, reports, and impact stories to help
          preserve the record of Scouting service in the Maldives.
        </p>
      </div>

      <div class="projects-cta-band__actions fade-in">
        <a href="/contact" class="btn btn-primary">Submit Project</a>
        <a href="/photo-archive" class="btn btn-outline-light">Photo Archive</a>
      </div>
    </div>
  </section>

  <style>
    .projects-hero p {
      max-width: 55ch;
      margin-inline: auto;
    }

    .projects-intro {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding-block: var(--space-16);
    }

    .projects-intro__inner {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-12);
      align-items: start;
    }

    .projects-intro h2 {
      max-width: 12ch;
      color: var(--color-green);
    }

    .projects-intro p {
      font-size: var(--text-md);
      line-height: 1.8;
      color: var(--color-ink-muted);
      max-width: 65ch;
    }

    .projects-section {
      background: var(--color-cream);
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: var(--space-8);
      margin-top: var(--space-12);
    }

    .project-card {
      display: flex;
      flex-direction: column;
      background: var(--color-cream-light);
      border: 1px solid var(--color-border);
      border-radius: var(--border-radius-md);
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: transform var(--transition-base), box-shadow var(--transition-base);
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }

    .project-card__image {
      width: 100%;
      height: 260px;
      overflow: hidden;
      background: var(--color-cream);
    }

    .project-card__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .project-card:hover .project-card__image img {
      transform: scale(1.05);
    }

    .project-card__content {
      padding: var(--space-8);
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .project-card__meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .project-card h3 {
      color: var(--color-green);
      font-size: var(--text-xl);
      line-height: 1.25;
      margin-bottom: var(--space-4);
    }

    .project-card p {
      color: var(--color-ink-muted);
      line-height: 1.8;
      font-size: var(--text-sm);
    }

    .project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: var(--space-6);
    }

    .project-tag {
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(67, 2, 1, 0.08);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 700;
    }

    .project-link {
      display: inline-block;
      margin-top: auto;
      padding-top: var(--space-7);
      color: var(--color-red);
      font-size: var(--text-sm);
    }

    .project-impact {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
    }

    .project-impact__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }

    .impact-card {
      background: var(--color-cream);
      border: 1px solid var(--color-border);
      border-radius: var(--border-radius-md);
      padding: var(--space-8);
    }

    .impact-card span {
      display: inline-block;
      color: var(--color-red);
      font-family: var(--font-serif);
      font-size: var(--text-xl);
      font-weight: 700;
      margin-bottom: var(--space-4);
    }

    .impact-card h3 {
      color: var(--color-green);
      margin-bottom: var(--space-3);
    }

    .impact-card p {
      color: var(--color-ink-muted);
      line-height: 1.7;
      font-size: var(--text-sm);
    }

    .projects-cta-band {
      background-color: var(--color-green);
      padding-block: var(--space-16);
    }

    .projects-cta-band__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-8);
      flex-wrap: wrap;
    }

    .projects-cta-band h3 {
      color: var(--color-cream);
      font-size: var(--text-2xl);
      margin-bottom: var(--space-2);
    }

    .projects-cta-band p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.7;
    }

    .projects-cta-band__actions {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
    }

    .projects-cta-band .btn-outline-light {
      color: var(--color-cream);
      border-color: var(--color-cream-dark);
    }

    .projects-cta-band .btn-outline-light:hover {
      background: var(--color-cream);
      color: var(--color-green);
    }

    @media (max-width: 900px) {
      .projects-intro__inner,
      .project-impact__grid {
        grid-template-columns: 1fr;
      }

      .projects-grid {
        grid-template-columns: 1fr;
      }

      .projects-cta-band__inner {
        flex-direction: column;
        text-align: center;
      }

      .projects-cta-band__actions {
        justify-content: center;
      }
    }

    @media (max-width: 600px) {
      .project-card__image {
        height: 220px;
      }

      .project-card__content {
        padding: var(--space-6);
      }
    }
  </style>
</BaseLayout>