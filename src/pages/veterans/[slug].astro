---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { veterans } from "../../data/veterans";

export function getStaticPaths() {
  return veterans.map((veteran) => ({
    params: { slug: veteran.slug },
    props: { veteran },
  }));
}

const { veteran } = Astro.props;

const currentIndex = veterans.findIndex((item) => item.slug === veteran.slug);
const previousVeteran = currentIndex > 0 ? veterans[currentIndex - 1] : null;
const nextVeteran =
  currentIndex < veterans.length - 1 ? veterans[currentIndex + 1] : null;

const hasVideo = Boolean(veteran.video);
---

<BaseLayout
  title={veteran.fullName}
  description={veteran.shortBio}
>
  <section class="veteran-detail-hero">
    <div class="container veteran-detail-hero__inner">
      <a href="/veterans" class="back-link">
        ← Back to Veteran Stories
      </a>

      <div class="veteran-hero-card">
        <div class="veteran-hero-card__photo">
          <img
            src={veteran.profileImage}
            alt={veteran.profileImageAlt}
          />
        </div>

        <div class="veteran-hero-card__content">
          <span class="section-label">Veteran Scout</span>

          <h1>{veteran.fullName}</h1>

          <p class="veteran-hero-card__title">
            {veteran.title}
          </p>

          <div class="veteran-meta">
            {veteran.dateOfBirth && (
              <span>Date of Birth: {veteran.dateOfBirth}</span>
            )}

            <span>Scouting Heritage</span>
            <span>Maldives</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section veteran-overview-section">
    <div class="container veteran-overview-layout">
      <aside class="veteran-sidebar">
        <div class="veteran-sidebar-card">
          <span class="section-label">Profile</span>

          <h2>{veteran.fullName}</h2>

          <p>{veteran.shortBio}</p>
        </div>

        {hasVideo && (
          <div class="veteran-sidebar-card veteran-sidebar-card--highlight">
            <span class="section-label">Archive Video</span>

            <h2>Video Available</h2>

            <p>
              A video about this veteran is available in this profile.
            </p>

            <a href="#profile-video" class="veteran-sidebar-link">
              Watch Video →
            </a>
          </div>
        )}

        {veteran.timeline.length > 0 && (
          <div class="veteran-sidebar-card">
            <span class="section-label">Timeline</span>

            <h2>{veteran.timeline.length} Highlights</h2>

            <p>
              Key milestones from this veteran’s Scouting journey are preserved
              near the end of this profile.
            </p>
          </div>
        )}
      </aside>

      <article class="veteran-story">
        <header class="veteran-story__header">
          <span class="section-label">Biography</span>

          <h2>Overview</h2>

          <div class="divider"></div>

          <p>
            {veteran.shortBio}
          </p>
        </header>

        <div class="veteran-story-sections">
          {veteran.sections.map((section, index) => (
            <section class={`veteran-story-section ${section.image ? "has-image" : "no-image"}`}>
              <div class="veteran-story-section__text">
                <span class="veteran-story-section__number">
                  {String(index + 1).padStart(2, "0")}
                </span>

                <h3>{section.heading}</h3>

                {section.body.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.bullets && section.bullets.length > 0 && (
                  <ul>
                    {section.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}
              </div>

              {section.image && (
                <figure class="veteran-story-section__image">
                  <img
                    src={section.image}
                    alt={section.imageAlt || section.heading}
                    loading="lazy"
                  />
                </figure>
              )}
            </section>
          ))}
        </div>
      </article>
    </div>
  </section>

  {hasVideo && (
    <section class="section video-section" id="profile-video">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-label">Archive Video</span>

          <h2>Profile Video</h2>

          <div class="divider divider--center"></div>

          <p>
            A video preserving the story, memory, and contribution of this veteran Scout.
          </p>
        </div>

        <div class="video-card">
          <video
            controls
            playsinline
            preload="metadata"
          >
            <source src={veteran.video} type="video/mp4" />
            Your browser does not support video playback.
          </video>
        </div>
      </div>
    </section>
  )}

  {veteran.timeline.length > 0 && (
    <section class="section timeline-section">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-label">Timeline Highlights</span>

          <h2>Life in Scouting</h2>

          <div class="divider divider--center"></div>
        </div>

        <div class="mini-timeline">
          {veteran.timeline.map((item) => (
            <article class="mini-timeline__item">
              <div class="mini-timeline__date">{item.year}</div>

              <div class="mini-timeline__line">
                <span></span>
              </div>

              <div class="mini-timeline__content">
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="veteran-navigation">
    <div class="container veteran-navigation__inner">
      {previousVeteran ? (
        <a href={`/veterans/${previousVeteran.slug}`} class="veteran-nav-card">
          <span>Previous Profile</span>
          <strong>{previousVeteran.fullName}</strong>
        </a>
      ) : (
        <a href="/veterans" class="veteran-nav-card">
          <span>Back to Archive</span>
          <strong>Veteran Stories</strong>
        </a>
      )}

      {nextVeteran ? (
        <a
          href={`/veterans/${nextVeteran.slug}`}
          class="veteran-nav-card veteran-nav-card--next"
        >
          <span>Next Profile</span>
          <strong>{nextVeteran.fullName}</strong>
        </a>
      ) : (
        <a
          href="/contact"
          class="veteran-nav-card veteran-nav-card--next"
        >
          <span>Contribute</span>
          <strong>Submit a Story</strong>
        </a>
      )}
    </div>
  </section>

  <section class="veteran-cta">
    <div class="container veteran-cta__inner">
      <div>
        <h3>Help preserve more veteran stories.</h3>

        <p>
          Submit photographs, memories, documents, or video details to support
          the archive.
        </p>
      </div>

      <a href="/contact" class="btn btn-primary">
        Submit Materials
      </a>
    </div>
  </section>

  <style>
    .veteran-detail-hero {
      background:
        linear-gradient(
          180deg,
          rgba(35, 33, 20, 0.96),
          rgba(35, 33, 20, 0.9)
        ),
        var(--color-green);
      padding-block: clamp(6.5rem, 10vw, 8rem) clamp(3.5rem, 7vw, 5rem);
      color: var(--color-cream);
    }

    .veteran-detail-hero__inner {
      max-width: 1060px;
    }

    .back-link {
      display: inline-block;
      color: var(--color-cream-dark);
      text-decoration: none;
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: clamp(2rem, 4vw, 3rem);
      transition:
        color var(--transition-fast),
        transform var(--transition-fast);
    }

    .back-link:hover {
      color: var(--color-cream);
      transform: translateX(-4px);
    }

    .veteran-hero-card {
      display: grid;
      grid-template-columns: 330px minmax(0, 1fr);
      overflow: hidden;
      background: var(--color-cream);
      border: 1px solid rgba(247, 242, 235, 0.14);
      border-radius: 30px;
      box-shadow: 0 28px 74px rgba(0, 0, 0, 0.22);
    }

    .veteran-hero-card__photo {
      min-height: 380px;
      background: var(--color-cream);
      display: grid;
      place-items: center;
      padding: var(--space-8);
    }

    .veteran-hero-card__photo img {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      display: block;
      background: var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.12);
      box-shadow: 0 18px 42px rgba(42, 38, 24, 0.12);
    }

    .veteran-hero-card__content {
      padding: clamp(2.25rem, 5vw, 4rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
    }

    .veteran-hero-card__content h1 {
      color: var(--color-green);
      font-size: clamp(2.7rem, 5vw, 4.9rem);
      line-height: 0.98;
      margin: var(--space-4) 0 var(--space-5);
      max-width: 11ch;
    }

    .veteran-hero-card__title {
      color: var(--color-red);
      font-size: var(--text-md);
      font-weight: 800;
      line-height: 1.6;
      max-width: 44ch;
      margin-bottom: var(--space-7);
    }

    .veteran-meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
    }

    .veteran-meta span {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.65rem 0.95rem;
      background: rgba(125, 6, 5, 0.08);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      line-height: 1.25;
    }

    .veteran-overview-section {
      background: var(--color-cream);
    }

    .veteran-overview-layout {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: clamp(3rem, 6vw, 5rem);
      align-items: start;
      max-width: 1080px;
    }

    .veteran-sidebar {
      position: sticky;
      top: 120px;
      display: grid;
      gap: var(--space-5);
    }

    .veteran-sidebar-card {
      background: var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 20px;
      padding: var(--space-6);
      box-shadow:
        0 14px 32px rgba(42, 38, 24, 0.045),
        0 1px 0 rgba(255, 255, 255, 0.45) inset;
    }

    .veteran-sidebar-card--highlight {
      border-color: rgba(125, 6, 5, 0.22);
      background:
        linear-gradient(
          135deg,
          rgba(125, 6, 5, 0.06),
          transparent 52%
        ),
        var(--color-cream-light);
    }

    .veteran-sidebar-card h2 {
      color: var(--color-green);
      font-size: var(--text-lg);
      line-height: 1.2;
      margin: var(--space-4) 0 var(--space-3);
    }

    .veteran-sidebar-card p {
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.78;
      max-width: none;
      margin: 0;
    }

    .veteran-sidebar-link {
      display: inline-block;
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      margin-top: var(--space-5);
      transition:
        color var(--transition-fast),
        transform var(--transition-fast);
    }

    .veteran-sidebar-link:hover {
      color: var(--color-green);
      transform: translateX(4px);
    }

    .veteran-story {
      min-width: 0;
    }

    .veteran-story__header {
      margin-bottom: clamp(2.8rem, 5vw, 4rem);
      padding-bottom: clamp(2rem, 4vw, 3rem);
      border-bottom: 1px solid rgba(42, 38, 24, 0.12);
    }

    .veteran-story__header h2 {
      color: var(--color-green);
      font-size: clamp(2.2rem, 5vw, 3.6rem);
      line-height: 1.08;
      margin: var(--space-4) 0 var(--space-5);
      max-width: 12ch;
    }

    .veteran-story__header p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.9;
      margin-top: var(--space-7);
      max-width: 68ch;
    }

    .veteran-story-sections {
      display: grid;
      gap: clamp(2.6rem, 5vw, 4rem);
    }

    .veteran-story-section {
  display: grid;
  gap: clamp(1.8rem, 4vw, 3rem);
  align-items: center;
  padding-bottom: clamp(2.6rem, 5vw, 4rem);
  border-bottom: 1px solid rgba(42, 38, 24, 0.1);
}

.veteran-story-section.has-image {
  grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
}

.veteran-story-section.no-image {
  grid-template-columns: 1fr;
}

.veteran-story-section.no-image .veteran-story-section__text {
  max-width: 760px;
}

.veteran-story-section.no-image h3 {
  max-width: 24ch;
}

.veteran-story-section.no-image p {
  max-width: 72ch;
}

.veteran-story-section.has-image:nth-child(even) .veteran-story-section__image {
  order: -1;
}

    .veteran-story-section:last-child {
      padding-bottom: 0;
      border-bottom: 0;
    }

    .veteran-story-section__text {
      min-width: 0;
    }

    .veteran-story-section__number {
      display: block;
      font-family: var(--font-serif);
      color: rgba(125, 6, 5, 0.22);
      font-size: clamp(1.9rem, 4vw, 2.7rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.04em;
      margin-bottom: var(--space-4);
    }

    .veteran-story-section h3 {
      color: var(--color-green);
      font-size: clamp(1.35rem, 2.2vw, 1.85rem);
      line-height: 1.22;
      margin-bottom: var(--space-5);
      max-width: 18ch;
    }

    .veteran-story-section p {
      color: var(--color-ink-muted);
      font-size: var(--text-md);
      line-height: 1.88;
      margin-bottom: var(--space-5);
      max-width: 68ch;
    }

    .veteran-story-section p:last-child {
      margin-bottom: 0;
    }

    .veteran-story-section ul {
      display: grid;
      gap: var(--space-3);
      margin: var(--space-5) 0 0;
      padding-left: 1.2rem;
    }

    .veteran-story-section li {
      color: var(--color-ink-muted);
      line-height: 1.8;
      padding-left: 0.25rem;
    }

    .veteran-story-section li::marker {
      color: var(--color-red);
    }

    .veteran-story-section__image {
      margin: 0;
      width: 100%;
      border-radius: 22px;
      overflow: hidden;
      border: 0;
      background: transparent;
      box-shadow: none;
    }

    .veteran-story-section__image img {
      width: 100%;
      height: auto;
      max-height: 380px;
      display: block;
      object-fit: contain;
      object-position: center center;
      background: transparent;
      border: 0;
    }

    .video-section {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
    }

    .video-section .section-header p {
      max-width: 58ch;
      margin-inline: auto;
      line-height: 1.8;
    }

    .video-card {
      max-width: 880px;
      margin: var(--space-10) auto 0;
      border-radius: 26px;
      overflow: hidden;
      background: #000;
      border: 0;
      box-shadow: var(--shadow-lg);
    }

    .video-card video {
      width: 100%;
      aspect-ratio: 16 / 9;
      display: block;
      background: #000;
      object-fit: contain;
      border: 0;
      outline: 0;
    }

    .timeline-section {
      background: var(--color-cream);
      border-top: 1px solid var(--color-border);
    }

    .mini-timeline {
      position: relative;
      max-width: 900px;
      margin: var(--space-12) auto 0;
      display: grid;
      gap: clamp(2.25rem, 5vw, 3.25rem);
      padding-block: var(--space-4);
    }

    .mini-timeline::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 2px;
      transform: translateX(-50%);
      background: rgba(125, 6, 5, 0.22);
    }

    .mini-timeline__item {
      display: grid;
      grid-template-columns: 1fr 70px 1fr;
      align-items: center;
      gap: var(--space-5);
      position: relative;
    }

    .mini-timeline__date {
      color: var(--color-red);
      font-family: var(--font-serif);
      font-size: clamp(1.55rem, 3vw, 2.3rem);
      font-weight: 900;
      line-height: 1;
      text-align: right;
      letter-spacing: -0.03em;
    }

    .mini-timeline__line {
      display: grid;
      place-items: center;
      position: relative;
      z-index: 2;
    }

    .mini-timeline__line span {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--color-cream);
      border: 4px solid var(--color-red);
      box-shadow: 0 0 0 8px var(--color-cream);
      display: block;
    }

    .mini-timeline__content {
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.42),
          rgba(255, 255, 255, 0.12)
        ),
        var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 22px;
      padding: clamp(1.4rem, 3vw, 2rem);
      box-shadow:
        0 16px 38px rgba(42, 38, 24, 0.045),
        0 1px 0 rgba(255, 255, 255, 0.45) inset;
    }

    .mini-timeline__content p {
      color: var(--color-ink-muted);
      line-height: 1.8;
      max-width: 44ch;
      margin: 0;
    }

    .veteran-navigation {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      padding-block: var(--space-12);
    }

    .veteran-navigation__inner {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-5);
      max-width: 820px;
      margin-inline: auto;
    }

    .veteran-nav-card {
      display: block;
      text-decoration: none;
      background: var(--color-cream);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 18px;
      padding: var(--space-6);
      box-shadow:
        0 14px 32px rgba(42, 38, 24, 0.045),
        0 1px 0 rgba(255, 255, 255, 0.45) inset;
      transition:
        transform var(--transition-base),
        box-shadow var(--transition-base),
        border-color var(--transition-base);
    }

    .veteran-nav-card:hover {
      transform: translateY(-4px);
      box-shadow:
        0 22px 52px rgba(42, 38, 24, 0.08),
        0 1px 0 rgba(255, 255, 255, 0.5) inset;
      border-color: rgba(125, 6, 5, 0.24);
    }

    .veteran-nav-card span {
      display: block;
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: var(--space-3);
    }

    .veteran-nav-card strong {
      display: block;
      color: var(--color-green);
      font-size: var(--text-md);
      line-height: 1.35;
    }

    .veteran-nav-card--next {
      text-align: right;
    }

    .veteran-cta {
      background: var(--color-green);
      padding-block: var(--space-16);
    }

    .veteran-cta__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-8);
      flex-wrap: wrap;
    }

    .veteran-cta h3 {
      color: var(--color-cream);
      font-size: var(--text-2xl);
      margin-bottom: var(--space-3);
      line-height: 1.2;
    }

    .veteran-cta p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.75;
    }

    @media (max-width: 1050px) {
      .veteran-hero-card,
      .veteran-overview-layout {
        grid-template-columns: 1fr;
      }

      .veteran-hero-card__photo {
        min-height: 300px;
      }

      .veteran-hero-card__photo img {
        width: 190px;
        height: 190px;
      }

      .veteran-sidebar {
        position: static;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .veteran-story-section,
.veteran-story-section.has-image,
.veteran-story-section.no-image {
  grid-template-columns: 1fr;
}

.veteran-story-section.has-image:nth-child(even) .veteran-story-section__image {
  order: initial;
}

.veteran-story-section.no-image .veteran-story-section__text {
  max-width: none;
}
    }

    @media (max-width: 820px) {
      .veteran-sidebar {
        grid-template-columns: 1fr;
      }

      .mini-timeline {
        max-width: 620px;
      }

      .mini-timeline::before {
        left: 9px;
      }

      .mini-timeline__item {
        grid-template-columns: 34px minmax(0, 1fr);
        gap: var(--space-4);
        align-items: start;
      }

      .mini-timeline__date {
        grid-column: 2;
        text-align: left;
        font-size: 1.6rem;
        margin-bottom: -0.35rem;
      }

      .mini-timeline__line {
        grid-column: 1;
        grid-row: 1 / span 2;
        place-items: start center;
        padding-top: 0.25rem;
      }

      .mini-timeline__line span {
        width: 16px;
        height: 16px;
        border-width: 4px;
        box-shadow: 0 0 0 7px var(--color-cream);
      }

      .mini-timeline__content {
        grid-column: 2;
      }

      .veteran-navigation__inner {
        grid-template-columns: 1fr;
      }

      .veteran-nav-card--next {
        text-align: left;
      }
    }

    @media (max-width: 700px) {
      .veteran-detail-hero {
        padding-block: var(--space-20) var(--space-12);
      }

      .veteran-hero-card,
      .veteran-sidebar-card,
      .video-card,
      .veteran-nav-card,
      .mini-timeline__content {
        border-radius: 20px;
      }

      .veteran-hero-card__photo {
        min-height: 270px;
        padding: var(--space-6);
      }

      .veteran-hero-card__photo img {
        width: 170px;
        height: 170px;
      }

