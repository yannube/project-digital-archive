---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Mahaldheeb Scoutun — Project Digital Archive preserving the history and legacy of Scouting in the Maldives.">

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg-pattern"></div>

    <div class="hero__content container">
      <div class="hero__badge">
        <span>⚜</span>
        <span>Est. 2025 · Maldives</span>
        <span>⚜</span>
      </div>

      <div class="hero-logo">
        <img src="/images/logo.svg" alt="Mahaldheeb Scoutun Logo" />
      </div>

      <p class="hero__tagline">
        Preserving the legacy of Maldivian Scouting<br class="hero__br" />
        for generations to come.
      </p>

      <div class="hero__actions">
        <a href="/history" class="btn btn-primary">Explore the Archive</a>
        <a href="/contact" class="btn btn-outline submit-visible">Submit Materials</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INTRODUCTION BAND
  ═══════════════════════════════════════════ -->
  <section class="intro-band">
    <div class="container intro-band__inner">
      <p class="intro-band__text">
        <strong>Project Digital Archive</strong> managed by the 14th Malé Rover Crew.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HIGHLIGHTS — 3 FEATURED CARDS
  ═══════════════════════════════════════════ -->
  <section class="section highlights">
    <div class="container">
      <div class="section-header text-center fade-in">
        <span class="section-label">Featured</span>
        <h2>From the Archive</h2>
        <div class="divider divider--center"></div>
        <p>A glimpse into the stories, images, and milestones we are preserving.</p>
      </div>

      <div class="highlights__grid">

        <article class="highlight-card fade-in">
          <div class="highlight-card__img highlight-card__img--history">
            <span class="highlight-card__year">1961</span>
          </div>

          <div class="highlight-card__body">
            <span class="section-label">Scouting History</span>
            <h3>The Beginning at Majeediyya School</h3>
            <p>
              Scouting in the Maldives traces its roots to 1961 when the first
              Scout group was formed under Principal Mr. J.V. Hill.
            </p>
            <a href="/history" class="btn btn-ghost">Read the History →</a>
          </div>
        </article>

        <article class="highlight-card fade-in">
          <div class="highlight-card__img highlight-card__img--veterans">
            <span class="highlight-card__year">Legacy</span>
          </div>

          <div class="highlight-card__body">
            <span class="section-label">Veteran Stories</span>
            <h3>Voices of Those Who Came Before</h3>
            <p>
              Personal narratives, memories, and contributions from the veterans
              who built Maldivian Scouting from the ground up.
            </p>
            <a href="/veterans" class="btn btn-ghost">Discover Stories →</a>
          </div>
        </article>

        <article class="highlight-card fade-in">
          <div class="highlight-card__img highlight-card__img--archive">
            <span class="highlight-card__year">Photos</span>
          </div>

          <div class="highlight-card__body">
            <span class="section-label">Photo Archive</span>
            <h3>A Visual Record of Scouting Life</h3>
            <p>
              Camps, jamborees, patrols, and badge ceremonies — documented in
              photographs spanning over six decades.
            </p>
            <a href="/photo-archive" class="btn btn-ghost">Browse Archive →</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TIMELINE TEASER
  ═══════════════════════════════════════════ -->
  <section class="section--sm timeline-teaser">
    <div class="container">
      <div class="section-header text-center fade-in">
        <span class="section-label">Milestones</span>
        <h2>Key Moments in History</h2>
        <div class="divider divider--center"></div>
      </div>

      <div class="timeline">
        <div class="timeline__item fade-in">
          <div class="timeline__year">1961</div>
          <div class="timeline__content">
            <h4>Scouting Begins</h4>
            <p>First Scout group formed at Majeediyya School, Malé.</p>
          </div>
        </div>

        <div class="timeline__item fade-in">
          <div class="timeline__year">1963</div>
          <div class="timeline__content">
            <h4>London Registration</h4>
            <p>Majeediyya Scout Group registered with Imperial Scout Headquarters in London.</p>
          </div>
        </div>

        <div class="timeline__item fade-in">
          <div class="timeline__year">1964</div>
          <div class="timeline__content">
            <h4>Sea Scouting</h4>
            <p>Sea Scouting introduced, reflecting the island nation's maritime heritage.</p>
          </div>
        </div>

        <div class="timeline__item fade-in">
          <div class="timeline__year">1984</div>
          <div class="timeline__content">
            <h4>Official Association</h4>
            <p>Maldives Boy Scouts Association officially registered on 28 January.</p>
          </div>
        </div>

        <div class="timeline__item fade-in">
          <div class="timeline__year">1986</div>
          <div class="timeline__content">
            <h4>First Jamboree</h4>
            <p>First National Scout Jamboree held at Kuda Bandos, 20–23 September.</p>
          </div>
        </div>
      </div>

      <div class="timeline-teaser__cta text-center fade-in">
        <a href="/timeline" class="btn btn-outline">View Timeline</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NAVIGATION CARDS
  ═══════════════════════════════════════════ -->
  <section class="section nav-cards">
    <div class="container">
      <div class="section-header text-center fade-in">
        <span class="section-label">Explore</span>
        <h2>What's Inside the Archive</h2>
        <div class="divider divider--center"></div>
      </div>

      <div class="nav-cards__grid">

        <a href="/history" class="nav-card fade-in">
          <h4>Scouting History</h4>
          <p>The full documented history of Maldivian Scouting from 1961 onwards.</p>
        </a>

        <a href="/timeline" class="nav-card fade-in">
          <h4>Timeline</h4>
          <p>Important milestones and key moments in the development of Scouting in the Maldives.</p>
        </a>

        <a href="/veterans" class="nav-card fade-in">
          <h4>Veteran Stories</h4>
          <p>Personal accounts from Scouts and leaders who shaped the movement.</p>
        </a>

        <a href="/photo-archive" class="nav-card fade-in">
          <h4>Photo Archive</h4>
          <p>Decades of Scouting life captured in photographs.</p>
        </a>

        <a href="/projects" class="nav-card fade-in">
          <h4>Scouting Projects</h4>
          <p>Community service, leadership, and impact projects by Scouts.</p>
        </a>

        <a href="/resources" class="nav-card fade-in">
          <h4>Resources</h4>
          <p>Training guides, documents, badges, and educational materials.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ABOUT PREVIEW
  ═══════════════════════════════════════════ -->
  <section class="section about-preview">
    <div class="container about-preview__inner">
      <div class="about-preview__text fade-in">
        <span class="section-label">About the Initiative</span>

        <h2>Why We Built This Archive</h2>

        <div class="divider"></div>

        <p>
          Mahaldheeb Scoutun is a Digital Archive initiative managed by the
          <strong>14th Malé Rover Crew</strong>.
        </p>

        <p>
          For decades, the Scouting movement in the Maldives has inspired countless
          young people, shaped leaders, and created unforgettable memories. Yet much
          of this rich legacy — the photographs, stories, training sessions, and
          veteran experiences — remains scattered, undocumented, and at risk of being
          lost forever.
        </p>

        <p>
          We created this archive because heritage matters. We believe that honoring
          our past strengthens our present and inspires our future. By documenting
          and preserving the essence of Scouting in the Maldives, we ensure that:
        </p>

        <ul class="about-preview__list">
          <li>Future generations can learn from those who came before them.</li>
          <li>The values and impact of the Scout movement are never forgotten.</li>
          <li>Our community's achievements are celebrated and shared.</li>
          <li>The Scouting spirit continues to thrive in every corner of the Maldives.</li>
        </ul>

        <div class="about-preview__actions">
          <a href="/about" class="btn btn-primary">About the Team</a>
          <a href="/contact" class="btn btn-outline submit-visible">Submit Materials</a>
        </div>
      </div>

      <div class="about-preview__visual fade-in">
        <img
          src="/images/rovers-logo-white.svg"
          alt="Rovers of Thaajuddeen Logo"
          class="about-preview__logo about-preview__logo--rovers"
        />

        <p class="about-preview__crew">14th Malé Rover Crew</p>

        <p class="about-preview__award">Project Digital Archive</p>

        <div class="about-preview__tags">
          <span class="tag">Scout Association of Maldives</span>
          <span class="tag">Heritage Archive</span>
          <span class="tag">Managed by Rovers</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SUBMIT / CONTRIBUTE BAND
  ═══════════════════════════════════════════ -->
  <section class="contribute-band">
    <div class="container contribute-band__inner">
      <div class="fade-in">
        <span class="section-label">Contribute</span>

        <h3>Have a story, photo, or document to share?</h3>

        <p>Help us grow this archive. Submit your Scouting memories and materials.</p>
      </div>

      <a href="/contact" class="btn btn-primary contribute-band__button fade-in">
        Submit Materials
      </a>
    </div>
  </section>

</BaseLayout>

<style>
/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
.hero {
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
  background-color: var(--color-cream);
  padding-block: var(--space-32) var(--space-24);
}

.hero__bg-pattern {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(125, 6, 5, 0.04) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(180, 116, 100, 0.06) 0%, transparent 40%),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 80px,
      rgba(42, 38, 24, 0.015) 80px,
      rgba(42, 38, 24, 0.015) 81px
    );
  pointer-events: none;
}

.hero__content {
  text-align: center;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6);
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-2) var(--space-5);
  border: 1px solid var(--color-border);
  border-radius: 100px;
  background-color: rgba(236, 226, 209, 0.6);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-red);
}

.hero__badge span:first-child,
.hero__badge span:last-child {
  font-size: 0.9rem;
}

.hero-logo {
  width: min(620px, 88vw);
  margin-inline: auto;
}

.hero-logo img {
  width: 100%;
  height: auto;
  display: block;
}

.hero__tagline {
  font-size: clamp(var(--text-md), 2vw, var(--text-xl));
  color: var(--color-ink-muted);
  line-height: 1.6;
  max-width: 50ch;
  margin-inline: auto;
}

.hero__br {
  display: block;
}

.hero__actions {
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
  justify-content: center;
  margin-top: var(--space-2);
}

.submit-visible {
  box-shadow: 0 10px 28px rgba(67, 2, 1, 0.12);
}

.hero__scroll-hint {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink-muted);
}

.hero__scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--color-red), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%,
  100% {
    opacity: 0.3;
    transform: scaleY(1);
  }

  50% {
    opacity: 1;
    transform: scaleY(1.2);
  }
}

/* ═══════════════════════════════════════════
   INTRO BAND
═══════════════════════════════════════════ */
.intro-band {
  background-color: var(--color-red);
  padding-block: var(--space-8);
}

.intro-band__inner {
  display: flex;
  justify-content: center;
}

.intro-band__text {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-md), 2vw, var(--text-xl));
  font-style: italic;
  color: rgba(247, 242, 235, 0.92);
  text-align: center;
  max-width: 70ch;
  line-height: 1.7;
}

.intro-band__text strong {
  color: var(--color-cream-light);
  font-style: normal;
}

/* ═══════════════════════════════════════════
   HIGHLIGHTS
═══════════════════════════════════════════ */
.highlights {
  background-color: var(--color-cream-light);
}

.highlights__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
  margin-top: var(--space-2);
}

.highlight-card {
  background-color: var(--color-cream);
  border: 1px solid var(--color-border);
  border-radius: var(--border-radius-md);
  overflow: hidden;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base);
}

.highlight-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

.highlight-card__img {
  height: 200px;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: var(--space-4);
}

.highlight-card__img--history {
  background: linear-gradient(135deg, #2A2618 0%, #4E4730 60%, #716849 100%);
}

.highlight-card__img--veterans {
  background: linear-gradient(135deg, #430201 0%, #7D0605 60%, #BC0E0C 100%);
}

.highlight-card__img--archive {
  background: linear-gradient(135deg, #3a2a20 0%, #B47464 60%, #CE9A8E 100%);
}

.highlight-card__year {
  font-family: var(--font-serif);
  font-size: var(--text-4xl);
  font-weight: 700;
  color: rgba(247, 242, 235, 0.15);
  line-height: 1;
  position: absolute;
  bottom: var(--space-3);
  right: var(--space-4);
  letter-spacing: -0.02em;
}

.highlight-card__body {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.highlight-card__body h3 {
  font-size: var(--text-xl);
  color: var(--color-green);
  line-height: 1.3;
}

.highlight-card__body p {
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  line-height: 1.7;
}

/* ═══════════════════════════════════════════
   TIMELINE TEASER
═══════════════════════════════════════════ */
.timeline-teaser {
  background-color: var(--color-cream);
}

.timeline {
  position: relative;
  margin-block: var(--space-12);
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 120px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent,
    var(--color-border) 10%,
    var(--color-border) 90%,
    transparent
  );
}

.timeline__item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: var(--space-8);
  align-items: flex-start;
  padding-block: var(--space-6);
  position: relative;
}

.timeline__item::before {
  content: '';
  position: absolute;
  left: 116px;
  top: calc(var(--space-6) + 8px);
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background-color: var(--color-red);
  border: 2px solid var(--color-cream);
  box-shadow: 0 0 0 1px var(--color-red);
}

.timeline__year {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--color-red);
  text-align: right;
  padding-right: var(--space-8);
  padding-top: var(--space-1);
  line-height: 1;
}

.timeline__content {
  padding-left: var(--space-8);
}

.timeline__content h4 {
  font-size: var(--text-lg);
  color: var(--color-green);
  margin-bottom: var(--space-2);
}

.timeline__content p {
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  max-width: 55ch;
}

.timeline-teaser__cta {
  margin-top: var(--space-8);
}

/* ═══════════════════════════════════════════
   NAVIGATION CARDS
═══════════════════════════════════════════ */
.nav-cards {
  background-color: var(--color-cream-light);
}

.nav-cards__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
  margin-top: var(--space-2);
}

.nav-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-8) var(--space-6);
  background-color: var(--color-cream);
  border: 1px solid var(--color-border);
  border-top: 4px solid var(--color-green);
  border-radius: var(--border-radius-md);
  text-decoration: none;
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.nav-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background-color: var(--color-red);
  transform: scaleX(0);
  transition: transform var(--transition-base);
  transform-origin: left;
}

.nav-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--color-red);
}

.nav-card:hover::after {
  transform: scaleX(1);
}

.nav-card h4 {
  font-size: var(--text-lg);
  color: var(--color-green);
  line-height: 1.3;
}

.nav-card p {
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  line-height: 1.6;
}

/* ═══════════════════════════════════════════
   ABOUT PREVIEW
═══════════════════════════════════════════ */
.about-preview {
  background-color: var(--color-cream);
}

.about-preview__inner {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: var(--space-16);
  align-items: center;
}

.about-preview__text h2 {
  margin-bottom: var(--space-2);
}

.about-preview__text p {
  font-size: var(--text-md);
  line-height: 1.85;
  max-width: 65ch;
  color: var(--color-ink-muted);
  margin-bottom: var(--space-5);
}

.about-preview__text strong {
  color: var(--color-red);
  font-weight: 700;
}

.about-preview__list {
  display: grid;
  gap: var(--space-3);
  margin: var(--space-6) 0 0;
  padding-left: 1.25rem;
  max-width: 65ch;
}

.about-preview__list li {
  color: var(--color-ink-muted);
  line-height: 1.75;
  padding-left: var(--space-2);
}

.about-preview__actions {
  margin-top: var(--space-8);
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.about-preview__visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  padding: var(--space-12);
  background-color: var(--color-green);
  border-radius: var(--border-radius-md);
  text-align: center;
  box-shadow: var(--shadow-lg);
}

.about-preview__logo {
  width: min(260px, 70%);
  height: auto;
  display: block;
  margin-bottom: var(--space-2);
}

.about-preview__crew {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-cream);
  max-width: none;
}

.about-preview__award {
  font-size: var(--text-sm);
  color: var(--color-cream-dark);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  max-width: none;
}

.about-preview__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  justify-content: center;
  margin-top: var(--space-2);
}

.tag {
  padding: var(--space-1) var(--space-3);
  background-color: rgba(236, 226, 209, 0.1);
  border: 1px solid rgba(236, 226, 209, 0.2);
  border-radius: 100px;
  font-size: var(--text-xs);
  color: var(--color-cream-dark);
  letter-spacing: 0.05em;
}

/* ═══════════════════════════════════════════
   CONTRIBUTE BAND
═══════════════════════════════════════════ */
.contribute-band {
  background-color: var(--color-red);
  border-top: 1px solid rgba(247, 242, 235, 0.16);
  border-bottom: 1px solid rgba(247, 242, 235, 0.16);
  padding-block: var(--space-16);
}

.contribute-band__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
  flex-wrap: wrap;
}

.contribute-band .section-label {
  color: var(--color-cream-dark);
}

.contribute-band__inner h3 {
  font-size: var(--text-2xl);
  color: var(--color-cream-light);
  margin: var(--space-2) 0;
}

.contribute-band__inner p {
  font-size: var(--text-md);
  color: rgba(247, 242, 235, 0.84);
}

.contribute-band__button {
  background-color: var(--color-cream-light);
  color: var(--color-red);
  box-shadow: 0 14px 34px rgba(0, 0, 0, 0.16);
}

.contribute-band__button:hover {
  background-color: var(--color-cream);
  color: var(--color-red);
}

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width: 1024px) {
  .highlights__grid,
  .nav-cards__grid {
    grid-template-columns: repeat(2, 1fr);
  }

