      margin-bottom: var(--space-5);
      max-width: 12ch;
    }

    .guidelines-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      margin-top: var(--space-8);
      padding-left: 1.25rem;
    }

    .guidelines-list li {
      color: var(--color-ink-muted);
      line-height: 1.8;
    }

    .archive-form-card {
      background: var(--color-cream);
      border: 1px solid var(--color-border);
      border-radius: 32px;
      padding: var(--space-10);
      box-shadow: var(--shadow-md);
    }

    .form-card-header {
      margin-bottom: var(--space-8);
    }

    .form-card-header h3 {
      color: var(--color-green);
      margin-top: var(--space-2);
      margin-bottom: var(--space-3);
    }

    .form-card-header p {
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.75;
      max-width: 62ch;
    }

    .archive-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    .form-grid {
      display: grid;
      gap: var(--space-5);
    }

    .form-grid--two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .form-group label {
      color: var(--color-green);
      font-size: var(--text-sm);
      font-weight: 800;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 16px 18px;
      border-radius: 16px;
      border: 1px solid var(--color-border);
      background: var(--color-cream-light);
      font-family: inherit;
      font-size: var(--text-sm);
      color: var(--color-ink);
      transition:
        border-color var(--transition-fast),
        background var(--transition-fast),
        box-shadow var(--transition-fast);
    }

    .form-group textarea {
      resize: vertical;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--color-red);
      background: var(--color-cream);
      box-shadow: 0 0 0 4px rgba(125, 6, 5, 0.08);
    }

    .other-type-field {
      display: none;
      animation: otherFieldFade 0.25s ease forwards;
    }

    .other-type-field.is-visible {
      display: flex;
    }

    @keyframes otherFieldFade {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .upload-box {
      border: 2px dashed var(--color-border);
      border-radius: 20px;
      padding: var(--space-8);
      background: var(--color-cream-light);
    }

    .upload-box__title {
      color: var(--color-green);
      font-size: var(--text-md);
      font-weight: 800;
      margin-bottom: var(--space-2);
      max-width: none;
    }

    .upload-box__text {
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.75;
      margin-bottom: var(--space-6);
      max-width: 58ch;
    }

    .uploadcare--widget {
      font-family: inherit;
    }

    .uploadcare--widget__button {
      background: var(--color-green) !important;
      border-radius: 999px !important;
      font-weight: 800 !important;
    }

    .checkbox-wrap {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.7;
    }

    .checkbox-wrap input {
      margin-top: 4px;
    }

    .form-submit-row {
      display: flex;
      justify-content: flex-start;
      margin-top: var(--space-2);
    }

    .submit-button {
      width: auto;
      min-width: 220px;
      padding-inline: var(--space-8);
      box-shadow: 0 14px 34px rgba(67, 2, 1, 0.12);
    }

    .contact-cta-band {
      background: var(--color-green);
      padding-block: var(--space-16);
    }

    .contact-cta-band__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-8);
      flex-wrap: wrap;
    }

    .contact-cta-band h3 {
      color: var(--color-cream);
      font-size: var(--text-2xl);
      margin-bottom: var(--space-3);
    }

    .contact-cta-band p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.8;
    }

    .contact-cta-band .btn-outline-light {
      color: var(--color-cream);
      border-color: var(--color-cream-dark);
    }

    .contact-cta-band .btn-outline-light:hover {
      background: var(--color-cream);
      color: var(--color-green);
    }

    @media (max-width: 1050px) {
  .contribution-grid {
    grid-template-columns: 1fr;
    max-width: 760px;
    row-gap: var(--space-5);
  }

      .archive-form-layout {
        grid-template-columns: 1fr;
      }

      .archive-form-info h2 {
        max-width: 18ch;
      }
    }

    @media (max-width: 950px) {
      .contact-intro__inner {
