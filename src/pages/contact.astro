      }

      .contact-intro h2 {
        max-width: 18ch;
      }
    }

    @media (max-width: 760px) {
  .form-grid--two {
    grid-template-columns: 1fr;
  }

  .contribution-card {
    grid-template-columns: 1fr;
    min-height: auto;
    gap: var(--space-4);
  }

  .contribution-card__number {
    margin-bottom: var(--space-2);
  }

  .contribution-card h3,
  .contribution-card p {
    max-width: none;
  }
}

    @media (max-width: 700px) {
      .archive-form-card {
        padding: var(--space-7);
