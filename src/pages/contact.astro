---

<BaseLayout
  title="Contact & Contributions"
  description="Contribute photographs, stories, historical records, and Scouting materials to the Mahaldheeb Scoutun Digital Archive."
>
  <section class="page-hero contact-hero">
    <div class="container">
      <span class="section-label">
        Contributions & Communication
      </span>

      <h1>
        Contact<br />
        the Archive
      </h1>

      <p>
        Help preserve the history of Scouting in the Maldives by contributing
        photographs, documents, stories, reports, memorabilia, and historical records.
      </p>
    </div>
  </section>

  <section class="contact-intro">
    <div class="container contact-intro__inner">
      <div>
        <span class="section-label">
          National Preservation Effort
        </span>

        <h2>
          Every photograph, story, and document matters.
        </h2>
      </div>

      <p>
        Mahaldheeb Scoutun is a growing digital archive dedicated to preserving
        the history, heritage, and impact of Scouting across the Maldives.
        Contributions from Scout groups, veterans, leaders, and communities help
        strengthen this collective national memory.
      </p>
    </div>
  </section>

  <section class="section contribution-section">
    <div class="container">
      <div class="section-header text-center fade-in contribution-header">
        <span class="section-label">
          Archive Contributions
        </span>

        <h2>What can you contribute?</h2>

        <div class="divider divider--center"></div>

        <p>
          The archive welcomes historical and contemporary materials related to
          Scouting in the Maldives.
        </p>
      </div>

      <div class="contribution-grid">
        {contributionCards.map((card, index) => (
          <article class="contribution-card fade-in">
            <div class="contribution-card__number">
              {String(index + 1).padStart(2, "0")}
            </div>

            <div class="contribution-card__content">
              <span class="contribution-card__label">
                {card.label}
              </span>

              <h3>{card.title}</h3>

              <p>{card.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section archive-form-section">
    <div class="container archive-form-layout">
      <div class="archive-form-info fade-in">
        <span class="section-label">
          Submission Guidelines
        </span>

        <h2>
          Before submitting materials
        </h2>

        <div class="divider"></div>

        <ul class="guidelines-list">
          <li>Ensure historical information is as accurate as possible.</li>
          <li>Include dates, locations, names, and event details whenever available.</li>
          <li>Only submit content you own or have permission to share.</li>
          <li>Higher quality scans and photographs are preferred.</li>
          <li>Archive administrators may review and verify submissions before publishing.</li>
        </ul>
      </div>

      <div class="archive-form-card fade-in">
        <div class="form-card-header">
          <span class="section-label">
            Contribution Form
          </span>

          <h3>
            Submit to the Archive
          </h3>

          <p>
            Share details about the material you would like to contribute. The
            archive team will review your submission before anything is published.
          </p>
        </div>

        <form
          class="archive-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
        >
          <div class="form-grid form-grid--two">
            <div class="form-group">
              <label for="fullName">Full Name</label>

              <input
                id="fullName"
                name="Full Name"
                type="text"
                placeholder="Your name"
                required
              />
            </div>

            <div class="form-group">
              <label for="emailAddress">Email Address</label>

              <input
                id="emailAddress"
                name="Email Address"
                type="email"
                placeholder="your@email.com"
                required
              />
            </div>
          </div>

          <div class="form-grid form-grid--two">
            <div class="form-group">
              <label for="contactNumbers">Contact Number(s)</label>

              <input
                id="contactNumbers"
                name="Contact Number(s)"
                type="text"
                placeholder="Example: +960 7XXXXXX / +960 9XXXXXX"
              />
            </div>

            <div class="form-group">
              <label for="scoutGroupOrganisation">Scout Group / Organisation</label>

              <input
                id="scoutGroupOrganisation"
                name="Scout Group / Organisation"
                type="text"
                placeholder="Example: 14th Malé Rover Crew"
              />
            </div>
          </div>

          <div class="form-grid form-grid--two">
            <div class="form-group">
              <label for="atollSelect">Atoll</label>

              <select id="atollSelect" name="Atoll" required>
                <option value="" selected disabled>Select atoll</option>
                {atollData.map((item) => (
                  <option value={item.atoll}>{item.atoll}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label for="islandSelect">Island</label>

              <select id="islandSelect" name="Island" required disabled>
                <option value="" selected>Select an atoll first</option>
              </select>
            </div>
          </div>

          <div class="form-grid form-grid--two">
            <div class="form-group">
              <label for="contributionType">Contribution Type</label>

              <select id="contributionType" name="Contribution Type" required>
                <option value="" selected disabled>Select contribution type</option>
                {contributionTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div class="form-group other-type-field" id="otherTypeField">
              <label for="otherContributionType">Describe Other Type</label>

              <input
                id="otherContributionType"
                name="Other Contribution Type"
                type="text"
                placeholder="Example: Badge collection, uniform item, audio recording..."
              />
            </div>
          </div>

          <div class="form-group">
            <label for="titleSubject">Title / Subject</label>

            <input
              id="titleSubject"
              name="Title / Subject"
              type="text"
              placeholder="Contribution title"
              required
            />
          </div>

          <div class="form-group">
            <label for="description">Description</label>

            <textarea
              id="description"
              name="Description"
              rows="6"
              placeholder="Describe the material, history, people involved, location, year, event, or story..."
              required
            ></textarea>
          </div>

          <div class="form-group">
            <label>File Upload</label>

            <div class="upload-box">
              <p class="upload-box__title">
                Upload photographs, documents, videos, or archive materials
              </p>

              <p class="upload-box__text">
                Files will be uploaded through Uploadcare. After upload, the file
                link will be included with your form submission.
              </p>

              <input
                type="hidden"
                role="uploadcare-uploader"
                name="Uploaded File Links"
                data-multiple="true"
                data-clearable="true"
                data-tabs="file camera url gdrive dropbox"
              />
            </div>
          </div>

          <label class="checkbox-wrap">
            <input type="checkbox" required />

            <span>
              I confirm that I own or have permission to share the submitted
              materials with Mahaldheeb Scoutun Project Digital Archive.
            </span>
          </label>

          <label class="checkbox-wrap">
            <input type="checkbox" required />

            <span>
              I understand that submitted materials may be reviewed, verified,
              archived, edited for clarity, and published on the website if accepted.
            </span>
          </label>

          <div class="form-submit-row">
            <button type="submit" class="btn btn-primary submit-button">
              Submit Contribution
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="contact-cta-band">
    <div class="container contact-cta-band__inner">
      <div class="fade-in">
        <h3>
          Building a national Scouting memory together.
        </h3>

        <p>
          Contributions from communities, Scout groups, leaders, and veterans help
          preserve the living history of Scouting in the Maldives.
        </p>
      </div>

      <div class="fade-in">
        <a href="/history" class="btn btn-outline-light">
          Explore the Archive
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    window.UPLOADCARE_PUBLIC_KEY = "YOUR_UPLOADCARE_PUBLIC_KEY";
  </script>

  <script
    src="https://ucarecdn.com/libs/widget/3.x/uploadcare.full.min.js"
    charset="utf-8"
  ></script>

  <script define:vars={{ atollData }} is:inline>
    const contributionTypeSelect = document.getElementById("contributionType");
    const otherTypeField = document.getElementById("otherTypeField");
    const atollSelect = document.getElementById("atollSelect");
    const islandSelect = document.getElementById("islandSelect");

    function toggleOtherTypeField() {
      if (!contributionTypeSelect || !otherTypeField) return;

      const shouldShow = contributionTypeSelect.value === "Other";
      otherTypeField.classList.toggle("is-visible", shouldShow);

      const otherInput = document.getElementById("otherContributionType");
      if (otherInput) {
        otherInput.required = shouldShow;
      }
    }

    function populateIslands() {
      if (!atollSelect || !islandSelect) return;

      const selectedAtoll = atollSelect.value;
      const selectedData = atollData.find((item) => item.atoll === selectedAtoll);

      islandSelect.innerHTML = "";

      if (!selectedData) {
        const option = document.createElement("option");
        option.value = "";
        option.textContent = "Select an atoll first";
        islandSelect.appendChild(option);
        islandSelect.disabled = true;
        return;
      }

      const defaultOption = document.createElement("option");
      defaultOption.value = "";
      defaultOption.textContent = "Select island";
      defaultOption.disabled = true;
      defaultOption.selected = true;
      islandSelect.appendChild(defaultOption);

      selectedData.islands.forEach((island) => {
        const option = document.createElement("option");
        option.value = island;
        option.textContent = island;
        islandSelect.appendChild(option);
      });

      islandSelect.disabled = false;
    }

    contributionTypeSelect?.addEventListener("change", toggleOtherTypeField);
    atollSelect?.addEventListener("change", populateIslands);

    toggleOtherTypeField();
    populateIslands();
  </script>

  <style>
    .contact-hero p {
      max-width: 60ch;
      margin-inline: auto;
    }

    .contact-intro {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding-block: var(--space-16);
    }

    .contact-intro__inner {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-12);
      align-items: start;
    }

    .contact-intro h2 {
      color: var(--color-green);
      max-width: 13ch;
    }

    .contact-intro p {
      color: var(--color-ink-muted);
      line-height: 1.9;
      font-size: var(--text-md);
      max-width: 65ch;
    }

    .contribution-section {
      background: var(--color-cream);
    }

    .contribution-header p {
      max-width: 58ch;
      margin-inline: auto;
      text-align: center;
      line-height: 1.8;
    }

    .contribution-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: clamp(1.5rem, 3vw, 2.25rem);
  row-gap: clamp(1.5rem, 3vw, 2.25rem);
  margin-top: var(--space-12);
  max-width: 1040px;
  margin-inline: auto;
}

.contribution-card {
  position: relative;
  min-height: 215px;
  display: grid;
  grid-template-columns: 78px minmax(0, 1fr);
  gap: clamp(1.15rem, 2.2vw, 1.6rem);
  align-items: start;
  background:
    linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.54),
      rgba(255, 255, 255, 0.18)
    ),
    var(--color-cream-light);
  border: 1px solid rgba(42, 38, 24, 0.13);
  border-radius: 24px;
  padding: clamp(1.75rem, 3vw, 2.15rem);
  overflow: hidden;
  box-shadow:
    0 16px 38px rgba(42, 38, 24, 0.045),
    0 1px 0 rgba(255, 255, 255, 0.45) inset;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base),
    border-color var(--transition-base);
}

.contribution-card::before {
  content: "";
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
  background: var(--color-red);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform var(--transition-base);
}

.contribution-card:hover {
  transform: translateY(-5px);
  box-shadow:
    0 24px 54px rgba(42, 38, 24, 0.08),
    0 1px 0 rgba(255, 255, 255, 0.5) inset;
  border-color: rgba(125, 6, 5, 0.24);
}

.contribution-card:hover::before {
  transform: scaleY(1);
}

.contribution-card__number {
  font-family: var(--font-serif);
  color: rgba(125, 6, 5, 0.18);
  font-size: clamp(2.65rem, 5vw, 3.7rem);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -0.04em;
  padding-top: 0.15rem;
}

.contribution-card__content {
  padding-top: 0.05rem;
}

.contribution-card__label {
  display: block;
  color: var(--color-red);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
  line-height: 1.35;
}

.contribution-card h3 {
  color: var(--color-green);
  font-size: clamp(1.25rem, 1.8vw, 1.55rem);
  line-height: 1.15;
  margin-bottom: var(--space-3);
  max-width: 15ch;
}

.contribution-card p {
  color: var(--color-ink-muted);
  line-height: 1.75;
  font-size: var(--text-sm);
  max-width: 38ch;
}

    .archive-form-section {
