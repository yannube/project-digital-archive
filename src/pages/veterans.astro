    }

    .veteran-role {
      color: var(--color-red);
      font-weight: 700;
      font-size: var(--text-sm);
      margin-bottom: var(--space-4);
    }

    .veteran-card p {
      color: var(--color-ink-muted);
      line-height: 1.75;
      font-size: var(--text-sm);
      padding-right: var(--space-3);
    }

    .veteran-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: var(--space-6);
    }

    .veteran-tags span {
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(67, 2, 1, 0.08);
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 800;
    }

    .oral-history {
      background: var(--color-cream);
    }

    .oral-history__inner {
      display: grid;
      grid-template-columns: 1fr 0.7fr;
      gap: var(--space-10);
