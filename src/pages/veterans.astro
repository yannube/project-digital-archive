---
import BaseLayout from "../layouts/BaseLayout.astro";
import { veterans, featuredVeteranSlug } from "../data/veterans";

const featuredVeteran =
  veterans.find((v) => v.slug === featuredVeteranSlug) || veterans[0];

const videoVeterans = veterans.filter((v) => v.video);
---

<BaseLayout
  title="Veteran Stories"
  description="Stories, memories, and contributions from the veteran Scouts who shaped Scouting in the Maldives."
>
  <section class="page-hero veterans-hero">
    <div class="container">
      <span class="section-label">Oral History Archive</span>

      <h1>
        Veteran<br />
        Stories
      </h1>

      <p>
        Preserving the voices, memories, service, and leadership of the people
        who helped shape Scouting in the Maldives.
      </p>
    </div>
  </section>

  <section class="legacy-intro">
    <div class="container legacy-intro__inner">
      <span class="section-label">A Legacy of Service</span>

      <h2>
        Their stories are not just memories.
        They are the foundation of the movement.
      </h2>

      <p>
        Through decades of voluntary service, veteran Scouts stood as mentors,
        educators, role models, and guardians of Scouting values. Their
        leadership helped shape the movement into what it is today.
      </p>
    </div>
  </section>

  <section class="section featured-veteran-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-label">An Inspiration to Us</span>

        <h2>Veteran Videos</h2>

        <div class="divider divider--center"></div>

        <p>
          A video collection preserving memories, reflections, and stories about
          veteran Scouts and their contributions.
        </p>
      </div>

      {videoVeterans.length > 0 ? (
        <div class="featured-video-card">
          <div class="featured-video-card__media">
            <video
              class="featured-video"
              controls
              playsinline
              preload="metadata"
            >
              <source src={featuredVeteran.video} type="video/mp4" />
              Your browser does not support video playback.
            </video>
          </div>

          <div class="featured-video-card__content">
            <span class="section-label">Featured Veteran Video</span>

            <h3>{featuredVeteran.fullName}</h3>

            <p class="featured-video-card__title">
              {featuredVeteran.title}
            </p>

            <p class="featured-video-card__text">
              This featured video preserves the story and contribution of a
              veteran Scout. More videos and archive materials can be added as
              the archive grows.
            </p>

            <a href={`/veterans/${featuredVeteran.slug}`} class="btn btn-primary featured-video-card__button">
              Read Full Profile
            </a>
          </div>
        </div>
      ) : (
        <div class="video-empty">
          <div class="video-empty__mark">MS</div>

          <h3>Veteran Videos Coming Soon</h3>

          <p>
            Veteran videos will appear here once they are added to the archive files.
          </p>
        </div>
      )}
    </div>
  </section>

  <section class="section veterans-collection">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-label">Guardians of Our History</span>

        <h2>Veteran Archive</h2>

        <div class="divider divider--center"></div>

        <p>
          Every veteran profile represents decades of service, mentorship,
          leadership, and commitment to the Scout Movement.
        </p>
      </div>

      <div class="veterans-grid">
        {veterans.map((veteran) => (
          <a href={`/veterans/${veteran.slug}`} class="veteran-card">
            <div class="veteran-card__portrait">
              <img
                src={veteran.profileImage}
                alt={veteran.profileImageAlt}
                loading="lazy"
              />
            </div>

            <div class="veteran-card__body">
              <span class="veteran-card__eyebrow">Veteran Scout</span>

              <h3>{veteran.fullName}</h3>

              <p class="veteran-card__subtitle">
                {veteran.cardSubtitle}
              </p>

              <p class="veteran-card__excerpt">
                {veteran.shortBio}
              </p>

              <div class="veteran-card__footer">
                <span>Read Profile</span>
                <strong>→</strong>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section--sm oral-history">
    <div class="container oral-history__inner">
      <div>
        <span class="section-label">Preserving Voices</span>

        <h2>Recorded Oral Histories</h2>

        <p>
          Future additions to this archive may include recorded interviews,
          audio memories, video reflections, and first-hand accounts from veteran
          Scouts and their families.
        </p>
      </div>

      <div class="oral-card">
        <span class="oral-card__mark">OH</span>

        <h3>Interview Archive</h3>

        <p>
          A dedicated space for preserving voices, not just written records.
        </p>
      </div>
    </div>
  </section>

  <section class="veterans-cta-band">
    <div class="container veterans-cta-band__inner">
      <div>
        <h3>
          Know a veteran Scout whose story should be preserved?
        </h3>

        <p>
          Help us preserve memories, photographs, and stories before they are
          lost to time.
        </p>
      </div>

      <div class="veterans-cta-band__actions">
        <a href="/contact" class="btn btn-primary">
          Submit a Story
        </a>

        <a href="/history" class="btn btn-outline-light">
          View History
        </a>
      </div>
    </div>
  </section>

  <style>
    .veterans-hero p {
      max-width: 60ch;
      margin-inline: auto;
    }

    .legacy-intro {
      position: relative;
      overflow: hidden;
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding-block: clamp(4.5rem, 8vw, 6.5rem);
    }

    .legacy-intro__inner {
      max-width: 860px;
      margin-inline: auto;
      text-align: center;
    }

    .legacy-intro h2 {
      color: var(--color-green);
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      line-height: 1.08;
      margin: var(--space-5) auto var(--space-6);
      max-width: 18ch;
    }

    .legacy-intro p {
      color: var(--color-ink-muted);
      line-height: 1.9;
      font-size: var(--text-md);
      max-width: 68ch;
      margin-inline: auto;
    }

    .featured-veteran-section {
      background: var(--color-cream);
    }

    .featured-veteran-section .section-header p,
    .veterans-collection .section-header p {
      max-width: 62ch;
      margin-inline: auto;
      line-height: 1.8;
    }

    .featured-video-card {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
      gap: 0;
      align-items: stretch;
      max-width: 1020px;
      margin: var(--space-12) auto 0;
      background: var(--color-green);
      border-radius: 28px;
      overflow: hidden;
      border: 1px solid rgba(42, 38, 24, 0.14);
      box-shadow: var(--shadow-lg);
    }

    .featured-video-card__media {
      min-height: 360px;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .featured-video {
      width: 100%;
      height: 100%;
      min-height: 360px;
      display: block;
      background: #000;
      object-fit: contain;
      outline: 0;
      border: 0;
    }

    .featured-video-card__content {
      padding: clamp(2.75rem, 4.5vw, 3.8rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
    }

    .featured-video-card__content .section-label {
      color: var(--color-cream-dark);
    }

    .featured-video-card__content h3 {
      color: var(--color-cream);
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      line-height: 1.04;
      margin: var(--space-4) 0 var(--space-4);
      max-width: 10ch;
    }

    .featured-video-card__title {
      color: var(--color-cream-dark);
      font-weight: 800;
      line-height: 1.6;
      margin-bottom: var(--space-5);
      max-width: 46ch;
    }

    .featured-video-card__text {
      color: rgba(247, 242, 235, 0.78);
      line-height: 1.9;
      max-width: 46ch;
      margin: 0;
    }

    .featured-video-card__button {
      margin-top: clamp(2rem, 4vw, 2.7rem);
      background: var(--color-cream);
      color: var(--color-green);
      padding: 0.95rem 1.65rem;
      line-height: 1;
    }

    .featured-video-card__button:hover {
      background: var(--color-cream-light);
      color: var(--color-red);
    }

    .video-empty {
      max-width: 680px;
      margin: var(--space-12) auto 0;
      text-align: center;
      padding: clamp(2.5rem, 6vw, 4rem);
      border-radius: 28px;
      border: 1px solid var(--color-border);
      background: var(--color-cream-light);
      box-shadow: var(--shadow-sm);
    }

    .video-empty__mark {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      margin: 0 auto var(--space-5);
      background: var(--color-green);
      color: var(--color-cream);
      font-family: var(--font-serif);
      font-weight: 900;
      font-size: var(--text-lg);
    }

    .video-empty h3 {
      color: var(--color-green);
      font-size: var(--text-2xl);
      margin-bottom: var(--space-3);
    }

    .video-empty p {
      color: var(--color-ink-muted);
      line-height: 1.8;
      max-width: 52ch;
      margin-inline: auto;
    }

    .veterans-collection {
      background: var(--color-cream-light);
      border-top: 1px solid var(--color-border);
    }

    .veterans-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(1.4rem, 3vw, 2rem);
      margin-top: var(--space-12);
      max-width: 1040px;
      margin-inline: auto;
    }

    .veteran-card {
      min-height: 100%;
      display: flex;
      flex-direction: column;
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.5),
          rgba(255, 255, 255, 0.14)
        ),
        var(--color-cream);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 24px;
      overflow: hidden;
      box-shadow:
        0 14px 32px rgba(42, 38, 24, 0.045),
        0 1px 0 rgba(255, 255, 255, 0.45) inset;
      text-decoration: none;
      transition:
        transform var(--transition-base),
        box-shadow var(--transition-base),
        border-color var(--transition-base);
    }

    .veteran-card:hover {
      transform: translateY(-6px);
      box-shadow:
        0 22px 52px rgba(42, 38, 24, 0.08),
        0 1px 0 rgba(255, 255, 255, 0.5) inset;
      border-color: rgba(125, 6, 5, 0.24);
    }

    .veteran-card__portrait {
      height: 210px;
      display: grid;
      place-items: center;
      background: var(--color-cream);
      border-bottom: 1px solid rgba(42, 38, 24, 0.08);
      padding: var(--space-6);
    }

    .veteran-card__portrait img {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      display: block;
      background: var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.12);
      box-shadow: 0 12px 28px rgba(42, 38, 24, 0.08);
      transition: transform var(--transition-base);
    }

    .veteran-card:hover .veteran-card__portrait img {
      transform: scale(1.035);
    }

    .veteran-card__body {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: var(--space-6);
    }

    .veteran-card__eyebrow {
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.35;
    }

    .veteran-card h3 {
      color: var(--color-green);
      margin: var(--space-3) 0 var(--space-3);
      font-size: clamp(1.35rem, 2vw, 1.65rem);
      line-height: 1.16;
    }

    .veteran-card__subtitle {
      color: var(--color-red);
      font-size: var(--text-xs);
      font-weight: 800;
      line-height: 1.55;
      margin-bottom: var(--space-4);
    }

    .veteran-card__excerpt {
      color: var(--color-ink-muted);
      line-height: 1.72;
      font-size: var(--text-sm);
      max-width: none;
      margin-bottom: var(--space-5);
    }

    .veteran-card__footer {
      margin-top: auto;
      padding-top: var(--space-4);
      border-top: 1px solid rgba(42, 38, 24, 0.1);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      color: var(--color-green);
    }

    .veteran-card__footer span {
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .veteran-card__footer strong {
      color: var(--color-red);
      font-size: 1.2rem;
      line-height: 1;
    }

    .oral-history {
      background: var(--color-cream);
    }

    .oral-history__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: var(--space-10);
      align-items: center;
    }

    .oral-history h2 {
      color: var(--color-green);
      font-size: clamp(2.1rem, 5vw, 3.4rem);
      line-height: 1.08;
      margin: var(--space-4) 0;
      max-width: 12ch;
    }

    .oral-history p {
      color: var(--color-ink-muted);
      line-height: 1.85;
      max-width: 65ch;
    }

    .oral-card {
      background: var(--color-cream-light);
      border: 1px solid rgba(42, 38, 24, 0.13);
      border-radius: 26px;
      padding: clamp(2rem, 4vw, 2.75rem);
      box-shadow: var(--shadow-md);
      overflow: hidden;
    }

    .oral-card__mark {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--color-green);
      color: var(--color-cream);
      font-family: var(--font-serif);
      font-weight: 900;
      font-size: var(--text-md);
      margin-bottom: var(--space-6);
    }

    .oral-card h3 {
      color: var(--color-green);
      font-size: var(--text-xl);
      margin-bottom: var(--space-4);
      line-height: 1.2;
    }

    .oral-card p {
      color: var(--color-ink-muted);
      font-size: var(--text-sm);
      line-height: 1.85;
      max-width: 32ch;
      margin: 0;
    }

    .veterans-cta-band {
      background: var(--color-green);
      padding-block: var(--space-16);
    }

    .veterans-cta-band__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-8);
      flex-wrap: wrap;
    }

    .veterans-cta-band h3 {
      color: var(--color-cream);
      font-size: var(--text-2xl);
      margin-bottom: var(--space-3);
      max-width: 720px;
      line-height: 1.2;
    }

    .veterans-cta-band p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.75;
    }

    .veterans-cta-band__actions {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
    }

    .btn-outline-light {
      color: var(--color-cream);
      border: 2px solid var(--color-cream-dark);
      background: transparent;
    }

    .btn-outline-light:hover {
      background: var(--color-cream);
      color: var(--color-green);
    }

    @media (max-width: 1050px) {
      .featured-video-card {
        grid-template-columns: 1fr;
      }

      .featured-video-card__media,
      .featured-video {
        min-height: 320px;
      }

      .veterans-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .oral-history__inner {
        grid-template-columns: 1fr;
      }

      .oral-card {
        max-width: 520px;
      }
    }

    @media (max-width: 720px) {
      .legacy-intro,
      .featured-veteran-section,
      .veterans-collection,
      .oral-history {
        padding-block: var(--space-12);
      }

      .featured-video-card {
        border-radius: 22px;
      }

      .featured-video-card__media,
      .featured-video {
        min-height: 240px;
      }

      .featured-video-card__content {
        padding: var(--space-7);
      }

      .veterans-grid {
        grid-template-columns: 1fr;
        gap: var(--space-6);
      }

      .veteran-card__portrait {
        height: 200px;
      }

      .veteran-card__portrait img {
        width: 140px;
        height: 140px;
      }

      .veteran-card__body {
        padding: var(--space-6);
      }

      .veterans-cta-band__inner {
        flex-direction: column;
        text-align: center;
      }

      .veterans-cta-band__actions {
        justify-content: center;
      }
    }
  </style>
</BaseLayout>