    }

    .veterans-cta-band p {
      color: var(--color-cream-dark);
      max-width: 60ch;
      line-height: 1.7;
    }

    .veterans-cta-band__actions {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
    }

    .btn-outline-light {
      color: var(--color-cream);
      border: 2px solid var(--color-cream-dark);
      background: transparent;
    }

    .btn-outline-light:hover {
      background: var(--color-cream);
      color: var(--color-green);
    }

    @media (max-width: 1000px) {
      .oral-history__inner {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 700px) {
      .interview-carousel {
        border-radius: 24px;
      }

      .interview-info {
        padding: var(--space-6);
      }

      .carousel-btn {
        width: 44px;
        height: 44px;
        font-size: 2rem;
      }

      .carousel-btn--prev {
