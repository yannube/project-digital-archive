---
// BaseLayout.astro — Mahaldheeb Scoutun
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mahaldheeb Scoutun',
  description = 'A digital heritage archive preserving the history and legacy of Scouting in the Maldives.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content={description} />

    <meta name="theme-color" content="#2A2618" />

    <link rel="icon" type="image/png" href="/images/logo-small.png" />

    <title>{title} — Mahaldheeb Scoutun</title>
  </head>

  <body>
    <!-- Premium Loading Screen -->
    <div id="site-loader" class="site-loader" aria-hidden="true">
      <div class="site-loader__pattern"></div>

      <div class="site-loader__inner">
        <div class="site-loader__logo-card">
          <img
            src="/images/logo.png"
            alt="Mahaldheeb Scoutun"
            class="site-loader__logo"
          />
        </div>

        <div class="site-loader__content">
          <span>Project Digital Archive</span>

          <div class="site-loader__progress">
            <i></i>
          </div>
        </div>
      </div>
    </div>

    <Navbar />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Loader + Scroll fade-in observer -->
    <script is:inline>
      const loader = document.getElementById("site-loader");

      window.addEventListener("load", () => {
        if (!loader) return;

        setTimeout(() => {
          loader.classList.add("site-loader--hidden");
        }, 520);

        setTimeout(() => {
          loader.remove();
        }, 1150);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.1,
          rootMargin: "0px 0px -40px 0px",
        }
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
      });
    </script>

    <style is:global>
      /* ═══════════════════════════════════════════
         PREMIUM PAGE LOADER
      ═══════════════════════════════════════════ */
      .site-loader {
        position: fixed;
        inset: 0;
        z-index: 999999;
        display: grid;
        place-items: center;
        overflow: hidden;
        background: var(--color-cream);
        transition:
          opacity 0.62s ease,
          visibility 0.62s ease;
      }

      .site-loader--hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .site-loader__pattern {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.55;
        background:
          radial-gradient(circle at 50% 42%, rgba(125, 6, 5, 0.08), transparent 34%),
          linear-gradient(
            90deg,
            transparent,
            transparent 78px,
            rgba(42, 38, 24, 0.025) 79px
          ),
          linear-gradient(
            0deg,
            transparent,
            transparent 78px,
            rgba(42, 38, 24, 0.018) 79px
          );
        background-size: auto, 80px 80px, 80px 80px;
      }

      .site-loader__inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--space-6);
        width: min(520px, 90vw);
        text-align: center;
        animation: loaderEnter 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
      }

      .site-loader__logo-card {
        position: relative;
        display: grid;
        place-items: center;
        width: min(280px, 62vw);
        aspect-ratio: 1 / 0.72;
      }

      .site-loader__logo-card::before {
        content: "";
        position: absolute;
        width: 82%;
        height: 58%;
        border-radius: 999px;
        background: rgba(125, 6, 5, 0.08);
        filter: blur(36px);
        animation: loaderGlow 1.9s ease-in-out infinite;
      }

      .site-loader__logo {
        position: relative;
        width: min(250px, 56vw);
        height: auto;
        display: block;
        filter: drop-shadow(0 18px 26px rgba(67, 2, 1, 0.14));
        animation: loaderLogo 2.2s ease-in-out infinite;
      }

      .site-loader__content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-4);
        width: 100%;
      }

      .site-loader__content span {
        color: var(--color-red);
        font-size: var(--text-xs);
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .site-loader__progress {
        width: min(220px, 58vw);
        height: 2px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(67, 2, 1, 0.14);
        margin-top: var(--space-1);
      }

      .site-loader__progress i {
        display: block;
        width: 44%;
        height: 100%;
        border-radius: inherit;
        background: var(--color-red);
        animation: loaderProgress 1.05s ease-in-out infinite;
      }

      @keyframes loaderEnter {
        from {
          opacity: 0;
          transform: translateY(10px) scale(0.98);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes loaderLogo {
        0%,
        100% {
          transform: translateY(0) scale(1);
        }

        50% {
          transform: translateY(-6px) scale(1.025);
        }
      }

      @keyframes loaderGlow {
        0%,
        100% {
          opacity: 0.5;
          transform: scale(0.96);
        }

        50% {
          opacity: 0.9;
          transform: scale(1.08);
        }
      }

      @keyframes loaderProgress {
        0% {
          transform: translateX(-120%);
        }

        50% {
          transform: translateX(72%);
        }

        100% {
          transform: translateX(260%);
        }
      }

      @media (max-width: 600px) {
        .site-loader__inner {
          gap: var(--space-5);
        }

        .site-loader__logo {
          width: min(220px, 62vw);
        }

        .site-loader__content span {
          font-size: 0.68rem;
          letter-spacing: 0.14em;
        }
      }
    </style>
  </body>
</html>