---
import { Image } from "astro:assets";
import logoSmall from "../../public/images/logo-beige.svg";

// Navbar.astro — Mahaldheeb Scoutun
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Scouting History", href: "/history" },
  { label: "Timeline", href: "/timeline" },
  { label: "Veteran Stories", href: "/veterans" },
  { label: "Photo Archive", href: "/photo-archive" },
  { label: "Projects", href: "/projects" },
  { label: "Resources", href: "/resources" },
  { label: "About Us", href: "/about" },
  { label: "Contact Us", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="navbar">
  <div class="navbar__inner container">
    <a href="/" class="navbar__brand" aria-label="Mahaldheeb Scoutun Home">
      <div class="navbar__brand-logo-wrap">
        <Image
          src={logoSmall}
          alt="Mahaldheeb Scoutun Logo"
          class="navbar__brand-logo"
          width={64}
          height={64}
        />
      </div>

      <div class="navbar__brand-text">
        <span class="navbar__brand-name">Mahaldheeb Scoutun</span>
        <span class="navbar__brand-sub">By 14th Malé Rover Crew</span>
      </div>
    </a>

    <nav class="navbar__nav" aria-label="Main navigation">
      <ul class="navbar__links">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`navbar__link${currentPath === link.href ? " navbar__link--active" : ""}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="navbar__toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="navbar__mobile" aria-hidden="true">
    <ul class="navbar__mobile-links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`navbar__mobile-link${currentPath === link.href ? " navbar__link--active" : ""}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background-color: var(--color-green);
    border-bottom: 2px solid var(--color-green-mid);
    box-shadow: var(--shadow-md);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: var(--space-6);
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
    min-width: 0;
  }

  .navbar__brand-logo-wrap {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .navbar__brand-logo {
    width: 52px;
    height: 52px;
    object-fit: contain;
    display: block;
  }

  .navbar__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
  }

  .navbar__brand-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-cream);
    white-space: nowrap;
  }

  .navbar__brand-sub {
    margin-top: 4px;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-cream-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .navbar__nav {
    display: flex;
    align-items: center;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    flex-wrap: nowrap;
  }

  .navbar__link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-cream-dark);
    text-decoration: none;
    border-radius: var(--border-radius);
    white-space: nowrap;
    position: relative;
    transition: color var(--transition-fast), background-color var(--transition-fast);
    -webkit-tap-highlight-color: transparent;
  }

  .navbar__link::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: var(--space-3);
    right: var(--space-3);
    height: 1px;
    background-color: var(--color-rose-light);
    transform: scaleX(0);
    transition: transform var(--transition-base);
    transform-origin: left;
  }

  .navbar__link:hover {
    color: var(--color-cream);
    background-color: rgba(236, 226, 209, 0.06);
  }

  .navbar__link:hover::after,
  .navbar__link--active::after {
    transform: scaleX(1);
  }

  .navbar__link--active {
    color: var(--color-cream) !important;
    background-color: rgba(236, 226, 209, 0.1);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 7px;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .navbar__toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-cream);
    border-radius: 999px;
    transition: all var(--transition-base);
  }

  .navbar__mobile {
    display: none;
  }

  .navbar__mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: 0;
    margin: 0;
  }

  .navbar__mobile-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-cream-dark);
    text-decoration: none;
    border-radius: var(--border-radius);
    transition: color var(--transition-fast), background-color var(--transition-fast);
    border-left: 2px solid transparent;
    -webkit-tap-highlight-color: transparent;
  }

  .navbar__mobile-link:hover,
  .navbar__mobile-link.navbar__link--active {
    color: var(--color-cream);
    background-color: rgba(236, 226, 209, 0.08);
    border-left-color: var(--color-rose-light);
  }

  @media (max-width: 1180px) {
    .navbar__nav {
      display: none;
    }

    .navbar__toggle {
      display: flex;
    }

    .navbar__mobile {
      display: block;
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      right: 0;
      background-color: rgba(24, 22, 15, 0.98);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: var(--space-4) var(--space-6);
      transform: translateY(-10px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity 0.25s ease,
        transform 0.25s ease,
        visibility 0.25s ease;
      z-index: 999;
    }

    .navbar__mobile.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  @media (max-width: 600px) {
    .navbar__inner {
      height: 76px;
    }

    .navbar__brand-logo-wrap {
      width: 48px;
      height: 48px;
    }

    .navbar__brand-logo {
      width: 48px;
      height: 48px;
    }

    .navbar__brand-name {
      font-size: 1.1rem;
    }

    .navbar__brand-sub {
      font-size: 0.58rem;
      max-width: 190px;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .navbar__mobile {
      padding: var(--space-4);
    }
  }

  @media (max-width: 380px) {
    .navbar__brand-name {
      font-size: 1rem;
    }

    .navbar__brand-sub {
      max-width: 160px;
    }
  }

  .navbar__toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navbar__toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .navbar__toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.querySelector(".navbar__toggle");
  const mobile = document.querySelector(".navbar__mobile");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.classList.toggle("open");

    mobile?.classList.toggle("open", isOpen);

    toggle.setAttribute("aria-expanded", String(isOpen));
    mobile?.setAttribute("aria-hidden", String(!isOpen));
  });

  document.querySelectorAll(".navbar__mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.classList.remove("open");
      mobile?.classList.remove("open");

      toggle?.setAttribute("aria-expanded", "false");
      mobile?.setAttribute("aria-hidden", "true");
    });
  });
</script>