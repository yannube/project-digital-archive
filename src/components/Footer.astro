---
// Footer.astro — Mahaldheeb Scoutun
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    heading: "Archive",
    links: [
      { label: "Scouting History",       href: "/history" },
      { label: "Veteran Stories",        href: "/veterans" },
      { label: "Photo Archive",          href: "/photo-archive" },
      { label: "Scouting Projects",      href: "/projects" },
    ]
  },
  {
    heading: "Explore",
    links: [
      { label: "Scouting Resources",     href: "/resources" },
      { label: "Scouting Across Isles",  href: "/isles" },
      { label: "Scout Shop",             href: "/shop" },
    ]
  },
  {
    heading: "Organisation",
    links: [
      { label: "About Us",               href: "/about" },
      { label: "Contact Us",             href: "/contact" },
    ]
  }
];
---

<footer class="footer">
  <div class="footer__top container">

    <!-- Brand Column -->
    <div class="footer__brand">
      <div class="footer__brand-icon">⚜</div>
      <p class="footer__brand-name">Mahaldheeb Scoutun</p>
      <p class="footer__brand-tagline">
        Preserving the legacy of Maldivian Scouting for future generations.
      </p>
      <p class="footer__managed">
        Managed by <strong>14th Malé Rover Crew</strong>
      </p>
    </div>

    <!-- Link Columns -->
    {footerLinks.map(col => (
      <div class="footer__col">
        <h4 class="footer__col-heading">{col.heading}</h4>
        <ul class="footer__col-links">
          {col.links.map(link => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}

  </div>

  <!-- Bottom Bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {currentYear} Mahaldheeb Scoutun. A Project Digital Archive Initiative.
      </p>
      <p class="footer__bp">
        BP Award Project — Scout Association of Maldives
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  background-color: var(--color-green);
  color: var(--color-cream-dark);
  margin-top: auto;
}

/* ── Top Section ── */
.footer__top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--space-12);
  padding-block: var(--space-16);
}

@media (max-width: 1024px) {
  .footer__top {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
}

@media (max-width: 600px) {
  .footer__top {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
}

/* ── Brand ── */
.footer__brand-icon {
  font-size: 2rem;
  color: var(--color-rose-light);
  margin-bottom: var(--space-3);
}

.footer__brand-name {
  font-family: var(--font-serif);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-cream);
  max-width: none;
  margin-bottom: var(--space-3);
  line-height: 1.3;
}

.footer__brand-tagline {
  font-size: var(--text-sm);
  color: var(--color-cream-dark);
  line-height: 1.7;
  margin-bottom: var(--space-4);
  max-width: 28ch;
}

.footer__managed {
  font-size: var(--text-xs);
  color: var(--color-green-light);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  max-width: none;
}

.footer__managed strong {
  color: var(--color-rose-light);
  font-weight: 600;
}

/* ── Link Columns ── */
.footer__col-heading {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-cream);
  margin-bottom: var(--space-5);
}

.footer__col-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer__link {
  font-size: var(--text-sm);
  color: var(--color-cream-dark);
  text-decoration: none;
  transition: color var(--transition-fast), padding-left var(--transition-fast);
  display: inline-block;
}

.footer__link:hover {
  color: var(--color-cream);
  padding-left: var(--space-2);
}

/* ── Bottom Bar ── */
.footer__bottom {
  border-top: 1px solid var(--color-green-mid);
  padding-block: var(--space-5);
}

.footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.footer__copy {
  font-size: var(--text-xs);
  color: var(--color-green-light);
  max-width: none;
}

.footer__bp {
  font-size: var(--text-xs);
  color: var(--color-rose);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  max-width: none;
}
</style>