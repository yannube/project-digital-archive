---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    heading: "Archive",
    links: [
      { label: "Scouting History", href: "/history" },
      { label: "Timeline", href: "/timeline" },
      { label: "Veteran Stories", href: "/veterans" },
      { label: "Photo Archive", href: "/photo-archive" },
      { label: "Scouting Projects", href: "/projects" },
    ],
  },
  {
    heading: "Explore",
    links: [
      { label: "Library", href: "/library" },
      { label: "Archive Items", href: "/archive" },
      { label: "Submit Materials", href: "/contact" },
    ],
  },
  {
    heading: "Organisation",
    links: [
      { label: "About Us", href: "/about" },
      { label: "Contact Us", href: "/contact" },
      { label: "Privacy Policy", href: "/privacy-policy" },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__top container">
    <div class="footer__brand">
      <img
        src="/images/logo-beige.svg"
        alt="Mahaldheeb Scoutun Logo"
        class="footer__logo"
      />

      <p class="footer__brand-name">Mahaldheeb Scoutun</p>

      <p class="footer__brand-tagline">
        Project Digital Archive
      </p>

      <p class="footer__managed">
        Managed by <strong>14th Malé Rover Crew</strong>
      </p>
    </div>

    {footerLinks.map((col) => (
      <div class="footer__col">
        <h4 class="footer__col-heading">{col.heading}</h4>

        <ul class="footer__col-links">
          {col.links.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {currentYear} Mahaldheeb Scoutun. A Project Digital Archive initiative.
      </p>

      <div class="footer__bottom-actions">
        <p class="footer__bp">
          Endorsed by The Scout Association of Maldives
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-green);
    color: var(--color-cream-dark);
    margin-top: auto;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer__logo {
    width: 165px;
    height: auto;
    display: block;
    margin-bottom: var(--space-6);
  }

  .footer__brand-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-cream);
    max-width: none;
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .footer__brand-tagline {
    font-size: var(--text-sm);
    color: var(--color-cream-dark);
    line-height: 1.7;
    margin-bottom: var(--space-4);
    max-width: 28ch;
  }

  .footer__managed {
    font-size: var(--text-xs);
    color: var(--color-rose-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    max-width: none;
  }

  .footer__managed strong {
    color: var(--color-rose-light);
    font-weight: 800;
  }

  .footer__col-heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cream);
    margin-bottom: var(--space-5);
  }

  .footer__col-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-cream-dark);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      padding-left var(--transition-fast);
    display: inline-block;
  }

  .footer__link:hover {
    color: var(--color-cream);
    padding-left: var(--space-2);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-green-mid);
    padding-block: var(--space-5);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-green-light);
    max-width: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer__bottom-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer__bp {
    font-size: var(--text-xs);
    color: var(--color-rose);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    max-width: none;
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 600px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__bottom-inner,
    .footer__bottom-actions {
      align-items: flex-start;
      justify-content: flex-start;
      flex-direction: column;
    }

    .footer__logo {
      width: 135px;
    }
  }
</style>