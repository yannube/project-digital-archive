---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    heading: "Archive",
    links: [
      { label: "Scouting History", href: "/history" },
      { label: "Timeline", href: "/timeline" },
      { label: "Veteran Stories", href: "/veterans" },
      { label: "Photo Archive", href: "/photo-archive" },
      { label: "Scouting Projects", href: "/projects" },
    ],
  },
  {
    heading: "Explore",
    links: [
      { label: "Library", href: "/library" },
      { label: "Archive Items", href: "/archive" },
      { label: "Submit Materials", href: "/contact" },
    ],
  },
  {
    heading: "Organisation",
    links: [
      { label: "About Us", href: "/about" },
      { label: "Contact Us", href: "/contact" },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__top container">
    <div class="footer__brand">
      <img
        src="/images/logo-beige.svg"
        alt="Mahaldheeb Scoutun Logo"
        class="footer__logo"
      />

      <p class="footer__brand-name">Mahaldheeb Scoutun</p>

      <p class="footer__brand-tagline">
        Project Digital Archive
      </p>

      <p class="footer__managed">
        Managed by <strong>14th Malé Rover Crew</strong>
      </p>
    </div>

    {footerLinks.map((col) => (
      <div class="footer__col">
        <h4 class="footer__col-heading">{col.heading}</h4>

        <ul class="footer__col-links">
          {col.links.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {currentYear} Mahaldheeb Scoutun. A Project Digital Archive initiative.
      </p>

      <div class="footer__bottom-actions">
        <button class="footer__privacy-button" type="button" data-privacy-open>
          Privacy Policy
        </button>

        <p class="footer__bp">
          Endorsed by The Scout Association of Maldives
        </p>
      </div>
    </div>
  </div>
</footer>

<div class="privacy-modal" id="privacy-modal" aria-hidden="true">
  <div class="privacy-modal__overlay" data-privacy-close></div>

  <div
    class="privacy-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="privacy-modal-title"
  >
    <button
      class="privacy-modal__close"
      type="button"
      aria-label="Close privacy policy"
      data-privacy-close
    >
      ×
    </button>

    <span class="section-label">Privacy Policy</span>

    <h2 id="privacy-modal-title">Mahaldheeb Scoutun Privacy Policy</h2>

    <div class="privacy-modal__content">
      <p>
        Mahaldheeb Scoutun Project Digital Archive collects contribution details
        only for archive review, verification, communication, and preservation
        purposes.
      </p>

      <h3>Information we may collect</h3>

      <p>
        When you submit materials, we may collect your name, email address,
        contact number, island or atoll, Scout group or organisation, contribution
        type, description, and any files or historical information you choose to
        provide.
      </p>

      <h3>How submissions are used</h3>

      <p>
        Submitted materials may be reviewed by archive administrators before being
        accepted, edited for clarity, verified, stored, or published on the website
        as part of the digital archive.
      </p>

      <h3>Ownership and permission</h3>

      <p>
        Contributors are responsible for ensuring that they own or have permission
        to share the materials they submit. By submitting materials, contributors
        confirm that the archive may review and preserve them for historical and
        educational purposes.
      </p>

      <h3>Personal information</h3>

      <p>
        Personal contact details are used for communication and verification.
        Contact information will not be publicly displayed unless permission is
        clearly given or the information is already part of a public historical
        record.
      </p>

      <h3>Review and removal</h3>

      <p>
        Archive administrators may refuse, edit, or remove materials if they are
        inaccurate, inappropriate, unverifiable, or submitted without proper
        permission. Contributors may contact the archive to request corrections or
        removal of submitted materials.
      </p>

      <h3>Future updates</h3>

      <p>
        This policy may be updated as the archive grows, especially when file
        uploads, Sanity CMS submissions, or other contribution systems are fully
        connected.
      </p>
    </div>
  </div>
</div>

<script>
  const privacyModal = document.getElementById("privacy-modal");
  const privacyOpenButtons = document.querySelectorAll("[data-privacy-open]");
  const privacyCloseButtons = document.querySelectorAll("[data-privacy-close]");

  function openPrivacyModal() {
    if (!privacyModal) return;
    privacyModal.classList.add("is-open");
    privacyModal.setAttribute("aria-hidden", "false");
    document.body.classList.add("privacy-modal-open");
  }

  function closePrivacyModal() {
    if (!privacyModal) return;
    privacyModal.classList.remove("is-open");
    privacyModal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("privacy-modal-open");
  }

  privacyOpenButtons.forEach((button) => {
    button.addEventListener("click", openPrivacyModal);
  });

  privacyCloseButtons.forEach((button) => {
    button.addEventListener("click", closePrivacyModal);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closePrivacyModal();
    }
  });
</script>

<style>
  .footer {
    background-color: var(--color-green);
    color: var(--color-cream-dark);
    margin-top: auto;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer__logo {
    width: 165px;
    height: auto;
    display: block;
    margin-bottom: var(--space-6);
  }

  .footer__brand-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-cream);
    max-width: none;
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .footer__brand-tagline {
    font-size: var(--text-sm);
    color: var(--color-cream-dark);
    line-height: 1.7;
    margin-bottom: var(--space-4);
    max-width: 28ch;
  }

  .footer__managed {
    font-size: var(--text-xs);
    color: var(--color-rose-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    max-width: none;
  }

  .footer__managed strong {
    color: var(--color-rose-light);
    font-weight: 800;
  }

  .footer__col-heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-cream);
    margin-bottom: var(--space-5);
  }

  .footer__col-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-cream-dark);
    text-decoration: none;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
    display: inline-block;
  }

  .footer__link:hover {
    color: var(--color-cream);
    padding-left: var(--space-2);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-green-mid);
    padding-block: var(--space-5);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-green-light);
    max-width: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer__bottom-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer__privacy-button {
    border: 0;
    background: transparent;
    color: var(--color-cream-dark);
    font: inherit;
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0;
    transition: color var(--transition-fast);
  }

  .footer__privacy-button:hover {
    color: var(--color-cream);
  }

  .footer__bp {
    font-size: var(--text-xs);
    color: var(--color-rose);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    max-width: none;
  }

  body.privacy-modal-open {
    overflow: hidden;
  }

  .privacy-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .privacy-modal.is-open {
    display: grid;
    place-items: center;
  }

  .privacy-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 18, 10, 0.72);
  }

  .privacy-modal__panel {
    position: relative;
    z-index: 1;
    width: min(760px, 100%);
    max-height: 86vh;
    overflow-y: auto;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: clamp(2rem, 5vw, 3.25rem);
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.35);
  }

  .privacy-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-green);
    color: var(--color-cream);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .privacy-modal h2 {
    color: var(--color-green);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.08;
    margin: var(--space-4) 0 var(--space-8);
    max-width: 12ch;
  }

  .privacy-modal__content {
    display: grid;
    gap: var(--space-5);
  }

  .privacy-modal__content h3 {
    color: var(--color-green);
    font-size: var(--text-md);
    margin-top: var(--space-2);
  }

  .privacy-modal__content p {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: 1.85;
    max-width: none;
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 600px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__bottom-inner,
    .footer__bottom-actions {
      align-items: flex-start;
      justify-content: flex-start;
      flex-direction: column;
    }

    .footer__logo {
      width: 135px;
    }
  }
</style>